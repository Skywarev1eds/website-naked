<div
  x-show="appTickets.modalIsOpen"
  x-cloak
  class="fixed inset-0 z-50 overflow-y-auto"
  aria-labelledby="ticket-modal-title"
  role="dialog"
  aria-modal="true"
>
  <div class="flex items-center justify-center min-h-screen px-4 text-center">
    <div
      x-show="appTickets.modalIsOpen"
      x-transition:enter="transition ease-out duration-300 transform"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200 transform"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      @click="appTickets.modalClose()"
      class="fixed inset-0 transition-opacity bg-black/75"
      aria-hidden="true"
    ></div>

    <div
      x-show="appTickets.modalIsOpen"
      x-transition:enter="transition ease-out duration-300 transform"
      x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
      x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
      x-transition:leave="transition ease-in duration-200 transform"
      x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
      x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
      class="inline-block w-full max-w-lg p-6 my-8 overflow-hidden text-left align-middle transition-all transform border-2 border-white/5 rounded-xl bg-background/75 backdrop-blur-lg text-t-primary"
    >
      <div class="flex items-start justify-between gap-4 mb-4">
        <h3 id="ticket-modal-title" class="text-xl font-bold truncate">
          Create a Support Ticket
        </h3>

        <button @click="appTickets.modalClose()" class="text-t-primary focus:outline-none hover:text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
        </button>
      </div>

      <form @submit.prevent="appTickets.submitTicket()">
        <div class="mb-4">
          <label class="block text-t-primary/80 mb-1">
            Invoice
          </label>
          <input
            type="text"
            x-model="appTickets.invoiceId"
            readonly
            class="w-full py-2 px-4 text-t-primary/60 bg-white/5 border border-white/5 rounded-lg pointer-events-none"
          />
        </div>

        <div class="mb-4">
          <label class="block text-t-primary/80 mb-1">
            Subject
          </label>
          <input
            type="text"
            x-model="appTickets.subject"
            x-ref="appTickets.subjectInput"
            placeholder="Brief description of your issue"
            maxlength="255"
            class="w-full py-2 px-4 text-t-primary bg-white/5 border border-white/5 rounded-lg focus:border-accent-500 focus:ring-accent-500 focus:ring-2 focus:ring-opacity-50 focus:outline-none"
            required
          />
        </div>

        <div>
          <label class="block text-t-primary/80 mb-1">
            Message
          </label>
          <textarea
            x-model="appTickets.message"
            placeholder="Please describe your issue in detail..."
            maxlength="8000"
            rows="6"
            class="w-full py-2 px-4 text-t-primary bg-white/5 border border-white/5 rounded-lg focus:border-accent-500 focus:ring-accent-500 focus:ring-2 focus:ring-opacity-50 focus:outline-none resize-vertical"
            required
          ></textarea>
        </div>

        <p x-show="appTickets.error" class="text-red-500 text-sm mt-2" x-text="appTickets.error"></p>

        <button
          type="submit"
          class="mt-4 px-6 py-2 rounded-full w-full flex justify-center items-center gap-3 border-2 font-semibold bg-accent-500 border-accent-500 text-t-accent hover:enabled:bg-accent-500/50 hover:enabled:text-t-primary transition-colors duration-300 ease-in-out disabled:opacity-50 disabled:pointer-events-none"
          :disabled="appTickets.loading"
        >
          <span>Submit Ticket</span>
          <template x-if="!appTickets.loading">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M16.15 13H5q-.425 0-.712-.288T4 12t.288-.712T5 11h11.15L13.3 8.15q-.3-.3-.288-.7t.288-.7q.3-.3.713-.312t.712.287L19.3 11.3q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.575 4.575q-.3.3-.712.288t-.713-.313q-.275-.3-.288-.7t.288-.7z"/></svg>
          </template>
          <template x-if="appTickets.loading">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-dasharray="16" stroke-dashoffset="16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3c4.97 0 9 4.03 9 9"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.2s" values="16;0"/><animateTransform attributeName="transform" dur="1.5s" repeatCount="indefinite" type="rotate" values="0 12 12;360 12 12"/></path></svg>
          </template>
        </button>
      </form>
    </div>
  </div>
</div>