<a
  class="border-2 border-white/5 rounded-xl bg-[rgba(255,255,255,0.01)] text-t-primary block hover:bg-[rgba(255,255,255,0.05)] transition-colors duration-300 ease-in-out"
  href="{{ 'javascript:void(0);' if product.type == 'group' else ( ('/product/' + product.path) | shopUrl ) }}"
  @click="{{ 'openGroupModal(' ~ product.id ~ ')' if product.type == 'group' else '' }}"
>
  <div class="relative p-2 mb-4">
    {% if product.image_urls|length > 0 %}
    <img src="{{ product.image_urls[0] }}" class="rounded-lg w-full {{ 'aspect-group-card-image object-group-image' if product.type == 'group' else 'aspect-product-card-image object-product-image' }}" loading="lazy" />
    {% elif product.image_url %}
    <img src="{{ product.image_url }}" class="rounded-lg w-full {{ 'aspect-group-card-image object-group-image' if product.type == 'group' else 'aspect-product-card-image object-product-image' }}" loading="lazy" />
    {% else %}
    <div class="flex justify-center items-center text-accent-400 {{ 'aspect-group-card-image' if product.type == 'group' else 'aspect-product-card-image' }}">
      <svg xmlns="http://www.w3.org/2000/svg" class="size-32" viewBox="0 0 256 256">
        <path
          fill="currentColor"
          d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z"
        />
      </svg>
    </div>
    {% endif %}

    {% if product.product_badges.card|length > 0 %}
      <div class="badges absolute top-2 right-2 flex items-center gap-2 flex-wrap">
        {% for productBadge in product.product_badges.card %}
          <div class="flex items-center gap-2 bg-accent-500 text-t-accent text-xs font-semibold px-2 py-1 rounded-lg" style="background-color: {{ productBadge.color }}" data-text="{{ productBadge.label }}" data-color="{{ productBadge.color }}">
            {% if productBadge.icon %}
              <i class="{{ productBadge.icon }} fa-fw"></i>
            {% endif %}
            {{ productBadge.label }}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
  <div class="text-left px-4 pb-4">
    <h3 class="text-xl font-bold mb-2 truncate">
      {{ product.name }}
    </h3>
    <p class="text-base text-t-primary/50 mb-4">
      {% if product.type == 'group' %}
      {{ product.products | length }} Products
      {% else %}
        {% if product.stock === 0 %}
        Out of Stock
        {% elif product.hide_stock_count %}
        In Stock
        {% elif product.stock === -1 %}
        <span class="inline-flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="text-accent-500 size-4" fill="currentColor" viewBox="0 0 256 256"><path d="M248,128a56,56,0,0,1-95.6,39.6l-.33-.35L92.12,99.55a40,40,0,1,0,0,56.9l8.52-9.62a8,8,0,1,1,12,10.61l-8.69,9.81-.33.35a56,56,0,1,1,0-79.2l.33.35,59.95,67.7a40,40,0,1,0,0-56.9l-8.52,9.62a8,8,0,1,1-12-10.61l8.69-9.81.33-.35A56,56,0,0,1,248,128Z"></path></svg>
          In Stock
        </span>
        {% else %}
        {{ product.stock + ' In Stock' }}
        {% endif %}
      {% endif %}
    </p>

    <div class="flex justify-between items-center">
      <div class="inline-flex items-center gap-2 truncate">
        <span class="text-sm text-t-primary/50">
          Price
        </span>
        <span class="text-lg font-semibold text-t-primary/50 truncate">
          <span class="text-accent-500">
            {% if product.min_price != product.max_price %}
              <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price, product.currency) }}
              </span>
              -
              <span x-text="appCurrency.format({{ product.max_price }}, '{{ product.currency }}')">
                {{ formatPrice(product.max_price, product.currency) }}
              </span>
            {% elif product.min_price %}
              <span x-text="appCurrency.format({{ product.min_price }}, '{{ product.currency }}')">
                {{ formatPrice(product.min_price, product.currency) }}
              </span>
            {% else %}
              -
            {% endif %}
          </span>

          {% if product.min_price_slash and product.max_price_slash %}
            {% if product.min_price_slash and product.max_price_slash and product.min_price_slash != product.max_price_slash %}
              <span class="text-sm line-through">
                <span x-text="appCurrency.format({{ product.min_price_slash }}, '{{ product.currency }}')">
                  {{ formatPrice(product.min_price_slash, product.currency) }}
                </span>
                -
                <span x-text="appCurrency.format({{ product.max_price_slash }}, '{{ product.currency }}')">
                  {{ formatPrice(product.max_price_slash, product.currency) }}
                </span>
              </span>
            {% elif product.min_price_slash %}
              <span class="text-sm line-through">
                <span x-text="appCurrency.format({{ product.min_price_slash }}, '{{ product.currency }}')">
                  {{ formatPrice(product.min_price_slash, product.currency) }}
                </span>
              </span>
            {% endif %}
          {% endif %}
        </span>
      </div>
      <span class="text-accent-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-9" viewBox="0 0 24 24"><path fill="currentColor" d="m12.2 13l-.9.9q-.275.275-.275.7t.275.7t.7.275t.7-.275l2.6-2.6q.3-.3.3-.7t-.3-.7l-2.6-2.6q-.275-.275-.7-.275t-.7.275t-.275.7t.275.7l.9.9H9q-.425 0-.712.288T8 12t.288.713T9 13zm-.2 9q-2.075 0-3.9-.788t-3.175-2.137T2.788 15.9T2 12t.788-3.9t2.137-3.175T8.1 2.788T12 2t3.9.788t3.175 2.137T21.213 8.1T22 12t-.788 3.9t-2.137 3.175t-3.175 2.138T12 22m0-2q3.35 0 5.675-2.325T20 12t-2.325-5.675T12 4T6.325 6.325T4 12t2.325 5.675T12 20m0-8"/></svg>
      </span>
    </div>
  </div>
</a>