<style>
  .bx-login-modal__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  .bx-login-modal__box {
    background: rgba(18,18,18,0.75);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 36px 32px;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04) inset;
  }

  .bx-login-modal__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 28px;
  }

  .bx-login-modal__icon {
    width: 44px; height: 44px;
    background: rgba(153,0,255,0.12);
    border: 1px solid rgba(153,0,255,0.3);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: #9900ff;
    flex-shrink: 0;
  }

  .bx-login-modal__titles { flex: 1; }

  .bx-login-modal__title {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    margin: 0 0 4px;
  }

  .bx-login-modal__sub {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }

  .bx-login-modal__close {
    background: none;
    border: none;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    padding: 4px;
    border-radius: 8px;
    transition: color 0.15s, background 0.15s;
  }

  .bx-login-modal__close:hover { color: #fff; background: rgba(255,255,255,0.06); }

  .bx-login-modal__label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.65);
    margin-bottom: 8px;
  }

  .bx-login-modal__hint {
    display: block;
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .bx-login-modal__input {
    width: 100%;
    padding: 11px 14px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: #fff;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .bx-login-modal__input:focus {
    border-color: rgba(153,0,255,0.5);
    box-shadow: 0 0 0 3px rgba(153,0,255,0.12);
  }

  .bx-login-modal__otp-row {
    display: flex;
    gap: 8px;
  }

  .bx-login-modal__otp-input {
    flex: 1;
    height: 48px;
    text-align: center;
    font-size: 18px;
    font-weight: 700;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: #fff;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .bx-login-modal__otp-input:focus {
    border-color: rgba(153,0,255,0.5);
    box-shadow: 0 0 0 3px rgba(153,0,255,0.12);
  }

  .bx-login-modal__error {
    font-size: 12px;
    color: #f87171;
    margin-top: 8px;
  }

  .bx-login-modal__btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
    padding: 13px 24px;
    background: #9900ff;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.15s, box-shadow 0.15s;
  }

  .bx-login-modal__btn:hover:not(:disabled) {
    opacity: 0.88;
    box-shadow: 0 4px 24px rgba(153,0,255,0.4);
  }

  .bx-login-modal__btn:disabled { opacity: 0.45; pointer-events: none; }
</style>

<div
  x-show="appCustomer.modalIsOpen"
  x-cloak
  class="bx-login-modal__backdrop"
  role="dialog"
  aria-modal="true"
>
  <div
    x-show="appCustomer.modalIsOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 translate-y-4 scale-95"
    x-transition:enter-end="opacity-100 translate-y-0 scale-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100 translate-y-0 scale-100"
    x-transition:leave-end="opacity-0 translate-y-4 scale-95"
    @click.stop
    class="bx-login-modal__box"
  >
    <div class="bx-login-modal__head">
      <div class="bx-login-modal__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <div class="bx-login-modal__titles">
        <h3 class="bx-login-modal__title">Welcome Back</h3>
        <p class="bx-login-modal__sub">Log in to your customer account</p>
      </div>
      <button class="bx-login-modal__close" @click="appCustomer.modalClose()" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Step 1: Email -->
    <div x-show="appCustomer.modalStep === 1">
      <form @submit.prevent="appCustomer.modalRequestOtp()">
        <label class="bx-login-modal__label">E-mail Address</label>
        <span class="bx-login-modal__hint">We'll send you a one-time password to this email address.</span>
        <input
          type="email"
          x-model="appCustomer.modalEmail"
          x-ref="appCustomer.modalEmailInput"
          placeholder="name@domain.com"
          class="bx-login-modal__input"
        />

        {% if altcha_shop_customer %}
          <div
            x-cloak
            x-show="!appCustomer.altchaPayload"
            class="mt-3 transition-opacity"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
          >
            <altcha-widget
              challengejson='{{ altcha_shop_customer | json }}'
              auto="onload"
              hidefooter="true"
              hidelogo="true"
              x-ref="appCustomer.altcha"
            ></altcha-widget>
          </div>
        {% endif %}

        <p x-show="appCustomer.modalEmailError" class="bx-login-modal__error" x-text="appCustomer.modalEmailError"></p>
        <button type="submit" class="bx-login-modal__btn" :disabled="appCustomer.modalLoading">
          <span>Continue</span>
          <template x-if="!appCustomer.modalLoading">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </template>
          <template x-if="appCustomer.modalLoading">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-dasharray="16" stroke-dashoffset="16" stroke-linecap="round" stroke-width="2" d="M12 3c4.97 0 9 4.03 9 9"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.2s" values="16;0"/><animateTransform attributeName="transform" dur="1.5s" repeatCount="indefinite" type="rotate" values="0 12 12;360 12 12"/></path></svg>
          </template>
        </button>
      </form>
    </div>

    <!-- Step 2: OTP -->
    <div x-show="appCustomer.modalStep === 2">
      <form @submit.prevent="appCustomer.modalLogin()">
        <label class="bx-login-modal__label">One-Time Password</label>
        <span class="bx-login-modal__hint">A 6-digit code has been sent to <strong x-text="appCustomer.modalEmail" style="color:rgba(255,255,255,0.65);"></strong>.</span>
        <div class="bx-login-modal__otp-row">
          {% for index in range(6) %}
          <input
            type="text"
            maxlength="1"
            x-model="appCustomer.modalOtpDigits[{{ index }}]"
            x-ref="appCustomer.modalOtpInputs[{{ index }}]"
            @input="appCustomer.modalOtpHandleInput({{ index }})"
            @keydown="appCustomer.modalOtpHandleKeyDown({{ index }}, $event)"
            class="bx-login-modal__otp-input"
          />
          {% endfor %}
        </div>
        <p x-show="appCustomer.modalOtpError" class="bx-login-modal__error" x-text="appCustomer.modalOtpError"></p>
        <button type="submit" class="bx-login-modal__btn" :disabled="appCustomer.modalLoading">
          <span>Log In</span>
          <template x-if="!appCustomer.modalLoading">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </template>
          <template x-if="appCustomer.modalLoading">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-dasharray="16" stroke-dashoffset="16" stroke-linecap="round" stroke-width="2" d="M12 3c4.97 0 9 4.03 9 9"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.2s" values="16;0"/><animateTransform attributeName="transform" dur="1.5s" repeatCount="indefinite" type="rotate" values="0 12 12;360 12 12"/></path></svg>
          </template>
        </button>
      </form>
    </div>

  </div>

  <!-- Backdrop click to close -->
  <div class="fixed inset-0 -z-10" @click="appCustomer.modalClose()"></div>
</div>
