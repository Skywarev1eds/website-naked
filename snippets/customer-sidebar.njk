<div class="bg-white/[0.025] backdrop-blur-2xl rounded-xl border-2 border-white/5 overflow-hidden">
  <div class="p-4 md:p-6 lg:p-8 border-b-2 border-white/5">
    <h3 class="text-xl font-bold text-t-primary">
      Customer Dashboard
    </h3>
    <p class="text-t-primary/80 mt-2">
      Logged in as {{ shop_customer.email }}
    </p>
  </div>
  <ul class="flex flex-col gap-4 p-4 md:p-6 lg:p-8 bg-black/5">
    <li>
      <a href="{{ '/customer/dashboard' | shopUrl }}" class="flex items-center gap-2.5 {{ 'text-accent-500' if templateName == 'customer-dashboard' else 'text-t-primary/80 hover:text-t-primary' }}">
        <span class="p-2 bg-white/[0.025] border border-white/5 rounded-md">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M5.85 17.1q1.275-.975 2.85-1.537T12 15t3.3.563t2.85 1.537q.875-1.025 1.363-2.325T20 12q0-3.325-2.337-5.663T12 4T6.337 6.338T4 12q0 1.475.488 2.775T5.85 17.1M12 13q-1.475 0-2.488-1.012T8.5 9.5t1.013-2.488T12 6t2.488 1.013T15.5 9.5t-1.012 2.488T12 13m0 9q-2.075 0-3.9-.788t-3.175-2.137T2.788 15.9T2 12t.788-3.9t2.137-3.175T8.1 2.788T12 2t3.9.788t3.175 2.137T21.213 8.1T22 12t-.788 3.9t-2.137 3.175t-3.175 2.138T12 22"/></svg>
        </span>
        <span>
          Dashboard
        </span>
      </a>
    </li>
    <li>
      <a href="{{ '/customer/invoices' | shopUrl }}" class="flex items-center gap-2.5 {{ 'text-accent-500' if templateName == 'customer-invoices' else 'text-t-primary/80 hover:text-t-primary' }}">
        <span class="p-2 bg-white/[0.025] border border-white/5 rounded-md">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M3 22V2l1.5 1.5L6 2l1.5 1.5L9 2l1.5 1.5L12 2l1.5 1.5L15 2l1.5 1.5L18 2l1.5 1.5L21 2v20l-1.5-1.5L18 22l-1.5-1.5L15 22l-1.5-1.5L12 22l-1.5-1.5L9 22l-1.5-1.5L6 22l-1.5-1.5zm3-5h12v-2H6zm0-4h12v-2H6zm0-4h12V7H6zM5 19.1h14V4.9H5zM5 4.9v14.2z"/></svg>
        </span>
        <span>
          Orders
        </span>
      </a>
    </li>
    {% if shop.tickets_enabled %}
      <li>
        <a href="{{ '/customer/tickets' | shopUrl }}" class="flex items-center gap-2.5 {{ 'text-accent-500' if templateName == 'customer-tickets' or templateName == 'customer-ticket' else 'text-t-primary/80 hover:text-t-primary' }}">
          <span class="p-2 bg-white/[0.025] border border-white/5 rounded-md">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M4 20q-.825 0-1.412-.587T2 18V6q0-.825.588-1.412T4 4h11q.475 0 .9.213t.7.587l4.5 6q.4.525.4 1.2t-.4 1.2l-4.5 6q-.275.375-.7.588T15 20zm0-2h11l4.5-6L15 6H4zm7.75-6"/></svg>
          </span>
          <span>
            Tickets
          </span>
        </a>
      </li>
    {% endif %}
    {% if shop.customer_balance_enabled %}
      <li>
        <a href="{{ '/customer/balance' | shopUrl }}" class="flex items-center justify-between gap-2.5 {{ 'text-accent-500' if templateName == 'customer-balance' else 'text-t-primary/80 hover:text-t-primary' }}">
          <span class="flex items-center gap-2.5">
            <span class="p-2 bg-white/[0.025] border border-white/5 rounded-md">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M11.1 19h1.75v-1.25q1.25-.225 2.15-.975t.9-2.225q0-1.05-.6-1.925T12.9 11.1q-1.5-.5-2.075-.875T10.25 9.2t.463-1.025T12.05 7.8q.8 0 1.25.387t.65.963l1.6-.65q-.275-.875-1.012-1.525T12.9 6.25V5h-1.75v1.25q-1.25.275-1.95 1.1T8.5 9.2q0 1.175.688 1.9t2.162 1.25q1.575.575 2.188 1.025t.612 1.175q0 .825-.587 1.213t-1.413.387t-1.463-.512T9.75 14.1l-1.65.65q.35 1.2 1.088 1.938T11.1 17.7zm.9 3q-2.075 0-3.9-.788t-3.175-2.137T2.788 15.9T2 12t.788-3.9t2.137-3.175T8.1 2.788T12 2t3.9.788t3.175 2.137T21.213 8.1T22 12t-.788 3.9t-2.137 3.175t-3.175 2.138T12 22m0-2q3.35 0 5.675-2.325T20 12t-2.325-5.675T12 4T6.325 6.325T4 12t2.325 5.675T12 20m0-8"/></svg>
            </span>
            <span>
              Balance
            </span>
          </span>
          <span>
            <span class="text-sm">
              <span x-text="appCurrency.format({{ shop_customer.balance }}, 'USD')">
                {{ formatPrice(shop_customer.balance, 'USD') }}
              </span>
            </span>
          </span>
        </a>
      </li>
    {% endif %}
    {% if shop.affiliate_enabled %}
      <li>
        <a href="{{ '/customer/affiliate' | shopUrl }}" class="flex items-center gap-2.5 {{ 'text-accent-500' if templateName == 'customer-affiliate' else 'text-t-primary/80 hover:text-t-primary' }}">
          <span class="p-2 bg-white/[0.025] border border-white/5 rounded-md">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M1 18q-.425 0-.712-.288T0 17v-.575q0-1.075 1.1-1.75T4 14q.325 0 .625.013t.575.062q-.35.525-.525 1.1t-.175 1.2V18zm6 0q-.425 0-.712-.288T6 17v-.625q0-.8.438-1.463t1.237-1.162T9.588 13T12 12.75q1.325 0 2.438.25t1.912.75t1.225 1.163t.425 1.462V17q0 .425-.287.713T17 18zm12.5 0v-1.625q0-.65-.162-1.225t-.488-1.075q.275-.05.563-.062T20 14q1.8 0 2.9.663t1.1 1.762V17q0 .425-.288.713T23 18zM8.125 16H15.9q-.25-.5-1.388-.875T12 14.75t-2.512.375T8.125 16M4 13q-.825 0-1.412-.587T2 11q0-.85.588-1.425T4 9q.85 0 1.425.575T6 11q0 .825-.575 1.413T4 13m16 0q-.825 0-1.412-.587T18 11q0-.85.588-1.425T20 9q.85 0 1.425.575T22 11q0 .825-.575 1.413T20 13m-8-1q-1.25 0-2.125-.875T9 9q0-1.275.875-2.137T12 6q1.275 0 2.138.863T15 9q0 1.25-.862 2.125T12 12m0-2q.425 0 .713-.288T13 9t-.288-.712T12 8t-.712.288T11 9t.288.713T12 10m0-1"/></svg>
          </span>
          <span>
            Affiliate
          </span>
        </a>
      </li>
    {% endif %}
    <li>
      <button type="button" @click="appCustomer.logout()" class="flex items-center gap-2.5 w-full cursor-pointer text-t-primary/80 hover:text-t-primary">
        <span class="p-2 bg-white/[0.025] border border-white/5 rounded-md">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M5 21q-.825 0-1.412-.587T3 19v-4h2v4h14V5H5v4H3V5q0-.825.588-1.412T5 3h14q.825 0 1.413.588T21 5v14q0 .825-.587 1.413T19 21zm5.5-4l-1.4-1.45L11.65 13H3v-2h8.65L9.1 8.45L10.5 7l5 5z"/></svg>
        </span>
        <span>
          Logout
        </span>
      </button>
    </li>
  </ul>
</div>