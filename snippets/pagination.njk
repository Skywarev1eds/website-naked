<div class="mt-4 md:mt-6">
    <nav role="navigation" aria-label="Pagination Navigation" class="flex items-center justify-between">
        <div class="flex justify-between flex-1 sm:hidden">
            {% if paginator.prev_page_url %}
                <a href="{{ paginator.prev_page_url }}" 
                   class="relative inline-flex items-center px-4 py-2 text-sm font-medium text-t-primary/80 bg-[rgba(255,255,255,0.01)] border border-white/5 rounded-md hover:text-white hover:bg-accent-500/10 focus:outline-none transition ease-in-out duration-150">
                    « Previous
                </a>
            {% else %}
                <span 
                   class="relative inline-flex items-center px-4 py-2 text-sm font-medium text-t-primary/50 bg-[rgba(255,255,255,0.01)] border border-white/5 cursor-default rounded-md">
                    « Previous
                </span>
            {% endif %}
            {% if paginator.next_page_url %}
                <a href="{{ paginator.next_page_url }}" 
                   class="relative inline-flex items-center px-4 py-2 ml-3 text-sm font-medium text-t-primary/80 bg-[rgba(255,255,255,0.01)] border border-white/5 rounded-md hover:text-white hover:bg-accent-500/10 focus:outline-none transition ease-in-out duration-150">
                    Next »
                </a>
            {% else %}
                <span 
                   class="relative inline-flex items-center px-4 py-2 ml-3 text-sm font-medium text-t-primary/50 bg-[rgba(255,255,255,0.01)] border border-white/5 cursor-default rounded-md">
                    Next »
                </span>
            {% endif %}
        </div>

        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
            <div>
                <p class="text-sm text-t-primary/80">
                    Showing
                    <span class="font-medium">{{ paginator.from }}</span>
                    to
                    <span class="font-medium">{{ paginator.to }}</span>
                    of
                    <span class="font-medium">{{ paginator.total }}</span>
                    results
                </p>
            </div>
            <div>
                <span class="relative z-0 inline-flex shadow-sm rounded-md">
                    {% if paginator.prev_page_url %}
                        <a href="{{ paginator.prev_page_url }}" 
                           class="relative inline-flex items-center px-2 py-2 text-sm font-medium text-t-primary/80 bg-[rgba(255,255,255,0.01)] border border-white/5 rounded-l-md hover:text-white hover:bg-accent-500/10 focus:z-10 focus:outline-none transition ease-in-out duration-150" 
                           aria-label="« Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="m13.15 16.15l-3.625-3.625q-.125-.125-.175-.25T9.3 12t.05-.275t.175-.25L13.15 7.85q.075-.075.163-.112T13.5 7.7q.2 0 .35.138T14 8.2v7.6q0 .225-.15.363t-.35.137q-.05 0-.35-.15"/></svg>
                        </a>
                    {% else %}
                        <span 
                           class="relative inline-flex items-center px-2 py-2 text-sm font-medium text-t-primary/50 opacity-50 border border-white/5 rounded-l-md cursor-default">
                            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="m13.15 16.15l-3.625-3.625q-.125-.125-.175-.25T9.3 12t.05-.275t.175-.25L13.15 7.85q.075-.075.163-.112T13.5 7.7q.2 0 .35.138T14 8.2v7.6q0 .225-.15.363t-.35.137q-.05 0-.35-.15"/></svg>
                        </span>
                    {% endif %}

                    {% for link in paginator.links %}
                        {% if link.label != '&laquo; Previous' and link.label != 'Next &raquo;' %}
                            {% if link.url %}
                                {% if link.active %}
                                    <span 
                                    aria-current="page" 
                                    class="relative inline-flex items-center px-4 py-2 -ml-px text-sm font-medium text-t-primary bg-accent-500 border border-accent-600 cursor-default">
                                        {{ link.label }}
                                    </span>
                                {% else %}
                                    <a href="{{ link.url }}" 
                                    class="relative inline-flex items-center px-4 py-2 -ml-px text-sm font-medium text-t-primary/80 bg-[rgba(255,255,255,0.01)] border border-white/5 hover:text-white hover:bg-accent-500/10 focus:z-10 focus:outline-none transition ease-in-out duration-150" 
                                    aria-label="Go to page {{ link.label }}">
                                        {{ link.label }}
                                    </a>
                                {% endif %}
                            {% endif %}
                        {% endif %}
                    {% endfor %}

                    {% if paginator.next_page_url %}
                        <a href="{{ paginator.next_page_url }}" 
                           rel="next" 
                           class="relative inline-flex items-center px-2 py-2 -ml-px text-sm font-medium text-t-primary/50 bg-[rgba(255,255,255,0.01)] border border-white/5 rounded-r-md hover:text-white hover:bg-accent-500/10 focus:z-10 focus:outline-none transition ease-in-out duration-150" 
                           aria-label="Next »">
                            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="M10.5 16.3q-.2 0-.35-.137T10 15.8V8.2q0-.225.15-.362t.35-.138q.05 0 .35.15l3.625 3.625q.125.125.175.25t.05.275t-.05.275t-.175.25L10.85 16.15q-.075.075-.162.113t-.188.037"/></svg>
                        </a>
                    {% else %}
                        <span 
                           class="relative inline-flex items-center px-2 py-2 -ml-px text-sm font-medium text-t-primary/50 opacity-50 border border-white/5 rounded-r-md cursor-default">
                            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="M10.5 16.3q-.2 0-.35-.137T10 15.8V8.2q0-.225.15-.362t.35-.138q.05 0 .35.15l3.625 3.625q.125.125.175.25t.05.275t-.05.275t-.175.25L10.85 16.15q-.075.075-.162.113t-.188.037"/></svg>
                        </span>
                    {% endif %}
                </span>
            </div>
        </div>
    </nav>
</div>