            "coupon": {
                "enabled": false,
                "show_logo": false,
                "headline": "Special Offer",
                "title": "Save 10% Today!",
                "description": "Get an exclusive discount on your next purchase. Limited time offer!",
                "coupon_code": "COUPONCODE",
