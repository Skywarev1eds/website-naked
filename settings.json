                    }
                ],
                "links_3_title": "Legal",
                "links_3": [
                    {
                        "text": "Terms of Service",
                        "link": "/terms-of-service"
                    },
                    {
                        "text": "Privacy Policy",
                        "link": "/privacy-policy"
                    },
                    {
                        "text": "Refund Policy",
                        "link": "/refund-policy"
                    }
                ]
