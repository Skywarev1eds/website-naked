{
    "templates": {
        "shop": {
            "layout": "master",
            "components": {
                "hero": {
                    "type": "hero",
                    "properties": {
                        "headline": "Trusted by over 740+ Satisfied Customers",
                        "title": "Dominate your games with Bxxgie's Closet",
                        "subtitle": "Premium game enhancements built for competitive players. Undetected, reliable, and updated daily.",
                        "show_searchbar": true,
                        "buttons": [
                            {
                                "text": "Products",
                                "icon": null,
                                "link": "/all-products",
                                "new_tab": false,
                                "color": "primary",
                                "style": "regular"
                            },
                            {
                                "text": "Sign In",
                                "icon": null,
                                "link": "#",
                                "new_tab": false,
                                "color": "secondary",
                                "style": "outline"
                            }
                        ],
                        "alignment": "center",
                        "height": "medium",
                        "text_width": "large",
                        "background_glow": true,
                        "background_image": "https://i.postimg.cc/sfwpf136/PURPLE-HERO.png",
                        "side_image": null,
                        "side_video_link": null
                    }
                },
                "about-us": {
                    "type": "about-us",
                    "properties": {
                        "title": "About us",
                        "text": "{{ shop.name }} is the ultimate solution for selling digital products online. With our extensive experience in running eCommerce stores, we understand the unique challenges that come with selling digital goods. This understanding has driven us to create {{ shop.name }}, empowering individuals like you to start selling digital products online with ease.",
                        "highlights": [
                            {
                                "title": "Instant Delivery",
                                "description": "We provide instant delivery for all of our products to ensure the best experience for our customers.",
                                "icon": "fas fa-star"
                            },
                            {
                                "title": "Secure Payments",
                                "description": "We use the latest technology to ensure that your payments are secure and your data is safe.",
                                "icon": "fas fa-star"
                            },
                            {
                                "title": "24/7 Support",
                                "description": "Our support team is available 24/7 to help you with any questions or issues you might have.",
                                "icon": "fas fa-star"
                            },
                            {
                                "title": "Huge Selection",
                                "description": "We offer a huge selection of products to ensure that you can find exactly what you need.",
                                "icon": "fas fa-star"
                            }
                        ]
                    }
                },
                "products": {
                    "type": "products",
                    "properties": {
                        "headline": "Best Sellers",
                        "title": "Featured Products",
                        "subtitle": "Explore our premium game enhancement tools, trusted by thousands of players worldwide.",
                        "centered": true,
                        "show_searchbar": true
                    }
                },
                "stats": {
                    "type": "stats",
                    "properties": {
                        "headline": "Customers Love Us ❤️",
                        "title": "Our Stats",
                        "subtitle": "Here are some of our key stats that show our success!",
                        "stats": [
                            {
                                "title": "Products Sold",
                                "value": "{{ shop.products_sold }}"
                            },
                            {
                                "title": "Happy Customers",
                                "value": "{{ shop.total_customers }}"
                            },
                            {
                                "title": "Average Rating",
                                "value": "{{ shop.average_rating }}"
                            }
                        ],
                        "animated": true
                    }
                },
                "feedbacks": {
                    "type": "feedbacks",
                    "properties": {
                        "title": "Reviews",
                        "subtitle": "See what our customers have to say about us and our products!",
                        "amount": 4
                    }
                },
                "socials": {
                    "type": "socials",
                    "properties": {
                        "headline": "Features",
                        "title": "Why Choose Us",
                        "subtitle": "Everything you need for the best gaming experience, backed by industry-leading security.",
                        "socials": [
                            {
                                "name": "Discord",
                                "icon": "fab fa-discord",
                                "link": "{{ shop.discord_url }}"
                            },
                            {
                                "name": "Telegram",
                                "icon": "fab fa-telegram",
                                "link": "{{ shop.telegram_url }}"
                            },
                            {
                                "name": "Instagram",
                                "icon": "fab fa-instagram",
                                "link": "{{ shop.instagram_url }}"
                            },
                            {
                                "name": "TikTok",
                                "icon": "fab fa-tiktok",
                                "link": "{{ shop.tiktok_url }}"
                            }
                        ]
                    }
                },
                "faq": {
                    "type": "faq",
                    "properties": {
                        "headline": "Questions",
                        "title": "Frequently Asked Questions",
                        "subtitle": "Everything you need to know about Bxxgie's Closet products and services.",
                        "items_per_row": 1,
                        "items": [
                            {
                                "question": "How do I receive my product after purchase?",
                                "answer": "After completing your purchase, your product will be delivered instantly to your customer dashboard. You'll also receive a confirmation email with your download link and license key."
                            },
                            {
                                "question": "Are your products safe and undetected?",
                                "answer": "Yes, all our products undergo rigorous testing before release. We use advanced anti-detection technology and our security team monitors game updates 24/7 to ensure our products remain undetected."
                            },
                            {
                                "question": "What payment methods do you accept?",
                                "answer": "We accept all major payment methods including Visa, Mastercard, PayPal, cryptocurrency (Bitcoin, Ethereum, Litecoin), Apple Pay, and Google Pay. All transactions are secured with end-to-end encryption."
                            },
                            {
                                "question": "How do I get support if I have issues?",
                                "answer": "Our support team is available via our Discord server at discord.gg/bxxgie. We typically respond within a few hours. Premium customers receive priority support with faster response times."
                            },
                            {
                                "question": "Do you offer refunds?",
                                "answer": "We offer refunds within 24 hours of purchase if the product is not working as described and our support team is unable to resolve the issue. Please review our refund policy for full details."
                            },
                            {
                                "question": "What if I get banned while using your products?",
                                "answer": "While our products are designed to be undetected, we cannot guarantee immunity from all anti-cheat systems. We recommend following our usage guidelines and safety tips provided in the product documentation."
                            }
                        ]
                    }
                },
                "blog-posts": {
                    "type": "blog-posts",
                    "properties": {
                        "headline": "Stay Updated 📢",
                        "title": "Latest Blog Posts",
                        "subtitle": "Check out our latest blog posts and stay updated with the latest news and trends.",
                        "amount": 4
                    }
                },
                "promoter": {
                    "type": "promoter",
                    "properties": {
                        "badge": "💰 Earn Money",
                        "title": "Join Our Media Programme",
                        "description": "Partner with Bxxgie's Closet and earn commission by promoting our premium products to your audience. Join our exclusive affiliate programme and start earning today.",
                        "link": "https://discord.gg/bxxgie",
                        "image": "https://i.postimg.cc/V6P3NDWb/PROMOTER-BXXGIES.png"
                    }
                }
            },
            "components_order": [
                "hero",
                "about-us",
                "products",
                "stats",
                "feedbacks",
                "socials",
                "faq",
                "promoter",
                "blog-posts"
