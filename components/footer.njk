<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

<style>
  .bx-footer {
    background: #080808;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 56px 24px 32px;
    font-family: 'Roboto', 'Poppins', sans-serif;
  }

  .bx-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .bx-footer__top {
    display: grid;
    grid-template-columns: 1fr auto auto auto;
    gap: 48px;
    align-items: start;
    margin-bottom: 48px;
  }

  @media (max-width: 900px) {
    .bx-footer__top { grid-template-columns: 1fr 1fr; gap: 32px; }
  }

  @media (max-width: 560px) {
    .bx-footer__top { grid-template-columns: 1fr; gap: 24px; }
  }

  .bx-footer__brand {}

  .bx-footer__logo-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .bx-footer__logo {
    height: 36px;
    width: auto;
    border-radius: 8px;
  }

  .bx-footer__shop-name {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
  }

  .bx-footer__tagline {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    line-height: 1.65;
    max-width: 280px;
    margin: 0 0 16px;
  }

  .bx-footer__status {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: rgba(34,197,94,0.08);
    border: 1px solid rgba(34,197,94,0.2);
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.55);
  }

  .bx-footer__status-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #22c55e;
    animation: bxStatusPulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes bxStatusPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.5); }
    50%       { box-shadow: 0 0 0 5px rgba(34,197,94,0); }
  }

  .bx-footer__nav-col {}

  .bx-footer__nav-title {
    font-size: 12px;
    font-weight: 700;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }

  .bx-footer__nav-list {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bx-footer__nav-list a {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.15s;
  }

  .bx-footer__nav-list a:hover { color: #fff; }

  .bx-footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-top: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .bx-footer__copy {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    line-height: 1.5;
  }

  .bx-footer__copy a { color: rgba(255,255,255,0.4); text-decoration: none; }
  .bx-footer__copy a:hover { color: rgba(255,255,255,0.65); }
</style>

<footer class="bx-footer component" data-component-id="footer">
  <div class="bx-footer__inner">

    <div class="bx-footer__top">

      <!-- Brand column -->
      <div class="bx-footer__brand">
        <div class="bx-footer__logo-row">
          {% if global.components.footer.show_logo and shop.image_url %}
            <img src="{{ shop.image_url }}" alt="{{ shop.name }}" class="bx-footer__logo">
          {% endif %}
          {% if global.components.footer.show_shop_name %}
            <span class="bx-footer__shop-name">{{ shop.name }}</span>
          {% endif %}
        </div>
        {% if global.components.footer.show_shop_description and shop.description %}
          <p class="bx-footer__tagline">{{ shop.description }}</p>
        {% else %}
          <p class="bx-footer__tagline">Premium game enhancements trusted by thousands of players worldwide.</p>
        {% endif %}
        <span class="bx-footer__status">
          <span class="bx-footer__status-dot"></span>
          All systems operational
        </span>
      </div>

      <!-- Store column -->
      {% if global.components.footer.links.length > 0 %}
      <div class="bx-footer__nav-col">
        <p class="bx-footer__nav-title">{{ global.components.footer.links_title if global.components.footer.links_title else 'Store' }}</p>
        <ul class="bx-footer__nav-list">
          {% for link in global.components.footer.links %}
          <li><a href="{{ link.link | shopUrl }}" target="{{ '_blank' if link.new_tab }}">{{ link.text }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <!-- Account column -->
      {% if not global.components.navbar.hide_customer_dashboard %}
      <div class="bx-footer__nav-col">
        <p class="bx-footer__nav-title">Account</p>
        <ul class="bx-footer__nav-list">
          {% if shop_customer %}
            <li><a href="{{ '/customer/dashboard' | shopUrl }}">My Account</a></li>
          {% else %}
            <li><a href="#" @click.prevent="appCustomer.loginOrRedirect()">Sign In</a></li>
          {% endif %}
        </ul>
      </div>
      {% endif %}

      <!-- Legal column -->
      <div class="bx-footer__nav-col">
        <p class="bx-footer__nav-title">Legal</p>
        <ul class="bx-footer__nav-list">
          <li><a href="{{ '/terms' | shopUrl }}">Terms</a></li>
          <li><a href="{{ '/privacy-policy' | shopUrl }}">Privacy</a></li>
          <li><a href="{{ '/refund-policy' | shopUrl }}">Refund</a></li>
        </ul>
      </div>

    </div>

    <div class="bx-footer__bottom">
      <p class="bx-footer__copy">
        {% if global.components.footer.copyright %}
          {{ global.components.footer.copyright | renderString }}
        {% else %}
          &copy; {{ shop.name }} 2026. All Rights Reserved. &middot; Developed by <a href="https://discord.gg/bxxgie" target="_blank">Cypher Designs</a>
        {% endif %}
      </p>
    </div>

  </div>
</footer>
