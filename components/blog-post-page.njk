<section class="component" data-component-id="{{ componentId }}">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="py-24 lg:py-32 relative">
      <div class="m-auto absolute inset-y-0 left-0 -z-10 aspect-square rounded-full blur-[200px] bg-accent-500/50 max-w-4xl -translate-y-1/2 w-[65%]" aria-hidden="true"></div>
      <div class="max-w-2xl text-left">
        <div class="mb-4">
          <span class="inline-block px-6 py-2 rounded-full border-2 border-white/5 bg-white/5 text-accent-100 text-sm font-semibold hover:translate-y-[-2px] transition-transform duration-300 ease-in-out" data-dsr>
            Blog
          </span>
        </div>
        <h1 class="text-4xl lg:text-5xl font-bold text-t-primary mb-4" data-dsr>
          {{ blogPost.title }}
        </h1>
        {% if blogPost.summary %}
          <p class="text-lg text-t-primary/50 mb-4" data-dsr>
            {{ blogPost.summary }}
          </p>
        {% endif %}
      </div>
    </div>

    <div class="flex flex-col gap-4 lg:flex-row lg:gap-8">
      <div class="lg:w-2/3" data-dsr>
        <div class="rounded-xl md:border-2 border-white/5 lg:p-8 text-t-primary mb-16 lg:mb-32" data-dsr>
          {% if blogPost.image_url %}
            <img src="{{ blogPost.image_url }}" class="rounded-lg w-full mb-4 lg:mb-8" loading="lazy" />
          {% endif %}

          <div class="editor">
            {{ blogPost.content | safe }}
          </div>

          <div class="flex items-center justify-end mt-4 lg:mt-8">
            <p class="text-sm text-t-primary/40">
              Published at
              <span class="font-medium">
                {{ blogPost.created_at | formatDate }}
              </span>
            </p>
          </div>
        </div>
      </div>
      <div class="lg:w-1/3" data-dsr>
        <div class="grid grid-cols-1 gap-4 lg:gap-8">
          {% for related_post in related_posts %}
            {% render_snippet "blog-post-card.njk", blogPost=related_post %}
          {% endfor %}
        </div>
    </div>
  </div>
</section>