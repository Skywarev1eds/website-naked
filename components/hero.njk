{% set containerHeightClassMap = {
  'short': '',
  'medium': 'min-h-[60vh]',
  'tall': 'min-h-[calc(100vh-112px)]'
} %}

{% set containerHeightClass = containerHeightClassMap[properties.height] %}

{% set heroAlignClassMap = {
  'left': 'flex-col md:flex-row md:justify-between',
  'center': 'flex-col',
  'right': 'flex-col md:flex-row-reverse md:justify-between'
} %}

{% set hcClass = heroAlignClassMap[properties.alignment] %}

{% set textWidthClassMap = {
  'small': 'max-w-md',
  'medium': 'max-w-xl',
  'large': 'max-w-3xl',
  'full': ''
} %}

{% set textAlignClassMap = {
  'left': 'text-left',
  'center': 'mx-auto text-center',
  'right': 'text-right'
} %}

{% set textClass = textWidthClassMap[properties.text_width] ~ ' ' ~ textAlignClassMap[properties.alignment] %}

{% set buttonAlignClassMap = {
  'left': 'justify-start',
  'center': 'justify-center',
  'right': 'justify-end'
} %}

{% set buttonClass = buttonAlignClassMap[properties.alignment] %}

{% set imageAlignClassMap = {
  'left': 'justify-end',
  'center': 'justify-center',
  'right': 'justify-start'
} %}

{% set imageClass = imageAlignClassMap[properties.alignment] %}

<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  {% set bgStyle = '' %}
  {% if properties.background_image %}
  {% set bgStyle = 'background-image: url(' ~ properties.background_image | imageUrl ~ ');' %}
  {% endif %}
  <div class="relative flex justify-center items-center py-24 bg-center bg-cover {{ containerHeightClass }}" style="{{ bgStyle }}">
    {% if properties.background_glow %}
    <div class="m-auto absolute inset-0 -z-10 aspect-square rounded-full blur-[200px] bg-accent-500/50 max-w-4xl -translate-y-2/3 w-[65%]" aria-hidden="true"></div>
    {% endif %}
    <div class="container relative flex gap-12 items-center px-4 {{ hcClass }}">
      <div class="flex flex-col gap-4 {{ textClass }}">
        {% if properties.headline %}
        <div>
          <span class="inline-block px-6 py-2 rounded-full border-2 border-white/5 bg-white/5 text-accent-100 text-sm font-semibold hover:translate-y-[-2px] transition-transform duration-300 ease-in-out" data-dsr>
            {{ properties.headline | renderString }}
          </span>
        </div>
        {% endif %}
        {% if properties.title %}
        <h1 class="text-5xl !leading-[1.125] font-bold text-t-primary mb-4" data-dsr>
          {{ properties.title | renderString }}
        </h1>
        {% endif %}
        {% if properties.subtitle %}
        <p class="text-base text-t-primary/50 mb-4" data-dsr>
          {{ properties.subtitle | renderString }}
        </p>
        {% endif %}
        {% if properties.show_searchbar %}
        {% render_snippet "searchbar.njk", alignment=properties.alignment %}
        {% endif %}
        {% if properties.buttons and properties.buttons.length > 0 %}
        <div class="flex flex-wrap items-center gap-4 mt-4 {{ buttonClass }}" data-dsr>
          {% render_snippet "buttons.njk", buttons=properties.buttons %}
        </div>
        {% endif %}
      </div>
      {% if properties.side_image %}
      <div class="flex items-center flex-1 min-w-[40%] {{ imageClass }}" data-dsr>
        <img src="{{ properties.side_image | imageUrl }}" alt="" class="max-w-full" />
      </div>
      {% elif properties.side_video_link %}
        <div class="flex items-center w-full min-w-[40%] aspect-video {{ imageClass }}" data-dsr>
          <lite-youtube videoid="{{ properties.side_video_link | ytEmbedVideoId }}" class="size-full rounded-xl aspect-video"></lite-youtube>
        </div>
      {% endif %}
    </div>
  </div>
</section>