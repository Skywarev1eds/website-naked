<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
  .hero-section *,
  .hero-section *::before,
  .hero-section *::after { box-sizing: border-box; }

  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px 100px;
    overflow: hidden;
    background: #080808;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    z-index: 0;
    opacity: 0.8;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(8,8,8,0.50) 0%,
      rgba(8,8,8,0.35) 40%,
      rgba(18,18,18,0.92) 85%,
      #121212 100%
    );
    z-index: 0;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,255,0,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,0,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 100%);
    z-index: 1;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 55% at 50% 50%, rgba(0,255,0,0.07) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-center {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 28px;
    max-width: 780px;
  }

  .hero-trust-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 999px;
    padding: 6px 14px 6px 8px;
    backdrop-filter: blur(8px);
    transition: border-color 0.3s, background 0.3s;
    animation: heroFadeUp 0.6s ease both;
  }

  .hero-trust-badge:hover {
    border-color: rgba(0,255,0,0.3);
    background: rgba(0,255,0,0.05);
  }

  .hero-trust-inner {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 400;
    color: rgba(255,255,255,0.55);
    line-height: 1;
    white-space: nowrap;
  }

  .hero-trust-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: rgba(0,255,0,0.1);
    border-radius: 50%;
    color: #00ff00;
    flex-shrink: 0;
  }

  .hero-trust-arrow {
    color: #00ff00;
    opacity: 0.75;
    flex-shrink: 0;
  }

  .hero-h1 {
    font-family: 'Roboto', sans-serif;
    font-size: clamp(38px, 6vw, 72px);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.01em;
    background: linear-gradient(180deg, #ffffff 10%, #00ff00 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: heroFadeUp 0.6s 0.1s ease both;
  }

  .hero-subtitle {
    font-size: clamp(14px, 1.6vw, 16px);
    color: rgba(255,255,255,0.45);
    font-weight: 300;
    line-height: 1.7;
    max-width: 520px;
    animation: heroFadeUp 0.6s 0.2s ease both;
  }

  .hero-btns {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    animation: heroFadeUp 0.6s 0.3s ease both;
  }

  .hero-prod-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #00ff00;
    color: #050505;
    font-family: 'Roboto', sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 11px 22px;
    border-radius: 8px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s, filter 0.2s;
    box-shadow: 0 0 24px rgba(0,255,0,0.2), 0 2px 8px rgba(0,0,0,0.4);
  }

  .hero-prod-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 36px rgba(0,255,0,0.35), 0 4px 16px rgba(0,0,0,0.5);
    filter: brightness(1.06);
  }

  .hero-prod-btn:active { transform: translateY(0); }

  .hero-dash-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: #f0f0f0;
    font-family: 'Roboto', sans-serif;
    font-size: 14px;
    font-weight: 400;
    padding: 10px 22px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.08);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.2s;
    text-decoration: none;
  }

  .hero-dash-btn:hover {
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.18);
    transform: translateY(-2px);
  }

  .hero-bottom-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 180px;
    background: linear-gradient(to bottom, transparent, #191919);
    z-index: 2;
    pointer-events: none;
  }

  .hero-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    opacity: 0.5;
    animation: heroFadeIn 1s 0.8s ease both;
  }

  .hero-chevron {
    animation: heroBounce 1.6s ease-in-out infinite;
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes heroFadeIn {
    from { opacity: 0; }
    to   { opacity: 0.5; }
  }

  @keyframes heroBounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(4px); }
  }
</style>

<div class="hero-section">
  {% if properties.background_image %}
  <div class="hero-bg" style="background-image: url('{{ properties.background_image | imageUrl }}');"></div>
  {% else %}
  <div class="hero-bg" style="background-image: url('https://i.postimg.cc/LsmfcZZ2/INDIGO-HERO.png');"></div>
  {% endif %}
  <div class="hero-overlay"></div>
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>

  <div class="hero-center">
    {% if properties.headline %}
    <div class="hero-trust-badge">
      <div class="hero-trust-inner">
        <span style="display:flex;align-items:center;gap:7px;">
          <span class="hero-trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 100 100" fill="currentColor">
              <path d="m50.027 10.459-.018-.032-33.606 19.404.076.132v22.893h.014c.286 19.111 14.859 34.755 33.519 36.718 18.66-1.962 33.234-17.606 33.519-36.718V29.953l.066-.114zm-.015 69.097V51.677H26.435V35.651L50.012 22.04v29.637h23.563v1.179h.017c-.278 13.593-10.439 24.798-23.58 26.7"/>
            </svg>
          </span>
          <span style="color:rgba(240,240,240,0.65);letter-spacing:0.01em;">{{ properties.headline | renderString }}</span>
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hero-trust-arrow">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </div>
    </div>
    {% endif %}

    {% if properties.title %}
    <h1 class="hero-h1">{{ properties.title | renderString }}</h1>
    {% endif %}

    {% if properties.subtitle %}
    <p class="hero-subtitle">{{ properties.subtitle | renderString }}</p>
    {% endif %}

    <div class="hero-btns">
      {% if properties.buttons and properties.buttons.length > 0 %}
        {% render_snippet "buttons.njk", buttons=properties.buttons %}
      {% else %}
        <a class="hero-prod-btn" href="{{ '/products' | shopUrl }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
            <path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>
          </svg>
          <span>Products</span>
        </a>
        {% if not global.components.navbar.hide_customer_dashboard %}
          {% if shop_customer %}
            <a href="{{ '/customer/dashboard' | shopUrl }}" class="hero-dash-btn">My Account</a>
          {% else %}
            <button type="button" class="hero-dash-btn" @click="appCustomer.loginOrRedirect()">Sign In</button>
          {% endif %}
        {% endif %}
      {% endif %}
    </div>
  </div>

  <div class="hero-bottom-fade"></div>

  <div class="hero-scroll">
    <svg class="hero-mouse" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="5" y="2" width="14" height="20" rx="7"/><path d="M12 6v4"/>
    </svg>
    <svg class="hero-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </div>
</div>

</section>