<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="container mx-auto flex flex-col px-4 mb-16 lg:mb-32">
    {% if properties.headline or properties.title or properties.subtitle %}
    <div class="flex flex-col gap-4 mb-8 text-center">
      {% if properties.headline %}
      <div>
        <span class="inline-block px-6 py-2 rounded-full border-2 border-white/5 bg-white/5 text-accent-100 text-sm font-semibold hover:translate-y-[-2px] transition-transform duration-300 ease-in-out" data-dsr>
          {{ properties.headline | renderString }}
        </span>
      </div>
      {% endif %}
      {% if properties.title %}
      <h2 class="text-4xl lg:text-5xl font-bold text-t-primary" data-dsr>
        {{ properties.title | renderString }}
      </h2>
      {% endif %}
      {% if properties.subtitle %}
      <p class="text-base text-t-primary/50" data-dsr>
        {{ properties.subtitle | renderString }}
      </p>
      {% endif %}
    </div>
    {% endif %}

    <div class="p-8 rounded-xl border-2 border-white/5 bg-black/5 backdrop-blur-2xl overflow-hidden relative lg:p-16" data-dsr>
      <div class="mx-auto absolute -z-10 aspect-square rounded-full -translate-y-1/3 left-0 top-0 -translate-x-1/3 blur-3xl bg-accent-500/40 w-[10%]" aria-hidden="true"></div>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-[repeat(auto-fit,_minmax(12rem,_1fr))]">
        {% for social in properties.socials %}
        <a href="{{ social.link | renderString }}" target="_blank" class="flex flex-col items-center gap-4 text-t-primary hover:text-accent-500">
          <span class="inline-flex justify-center items-center size-12 rounded-xl relative overflow-hidden bg-accent-500/20 border border-accent-500 text-accent-500">
            <i class="{{ social.icon }} fa-fw"></i>
          </span>
          <div class="flex-1">
            <h4 class="text-lg font-semibold">
              {{ social.name }}
            </h4>
          </div>
        </a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>