<nav class="component" data-component-id="navbar">

<style>
    body > nav.navbar,
    body > header > nav.navbar,
    .navbar:not(.nav):not(.mob-menu) {
        display: none !important;
    }

    :root {
        --accent: #9900ff;
        --accent-dim: rgba(128,0,255,.08);
        --border: rgba(255,255,255,.07);
        --muted: rgba(255,255,255,.55);
        --surface: rgba(255,255,255,.04);
        --radius: 10px;
    }

    .nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 1000;
        height: 64px;
        display: flex;
        align-items: center;
        padding: 0 2rem;
        gap: 2rem;
        background: transparent;
        border: 1px solid transparent;
        border-radius: 0;
        transition:
            top .35s cubic-bezier(.4,0,.2,1),
            left .35s cubic-bezier(.4,0,.2,1),
            right .35s cubic-bezier(.4,0,.2,1),
            height .35s cubic-bezier(.4,0,.2,1),
            padding .35s cubic-bezier(.4,0,.2,1),
            background .35s ease,
            border-color .35s ease,
            border-radius .35s ease,
            box-shadow .35s ease;
    }

    .nav.scrolled {
        top: 14px !important;
        left: 220px !important;
        right: 220px !important;
        height: 68px !important;
        padding: 0 1.5rem !important;
        background: rgba(10,10,10,0.45) !important;
        backdrop-filter: blur(24px) saturate(160%) !important;
        -webkit-backdrop-filter: blur(24px) saturate(160%) !important;
        border-radius: 18px !important;
        border: 1px solid rgba(255,255,255,0.07) !important;
        box-shadow: 0 8px 40px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.05) !important;
    }

    @media (max-width: 1400px) { .nav.scrolled { left: 160px !important; right: 160px !important; } }
    @media (max-width: 1200px) { .nav.scrolled { left: 60px !important;  right: 60px !important;  } }
    @media (max-width: 1080px) { .nav.scrolled { left: 24px !important;  right: 24px !important;  } }
    @media (max-width: 979px)  { .nav.scrolled { left: 16px !important;  right: 16px !important;  } }

    .nav__logo { height: 36px; width: auto; }

    .nav__links {
        display: flex;
        align-items: center;
        gap: .125rem;
        list-style: none;
        margin: 0; padding: 0;
        flex: 1;
    }

    .nav__links a {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: .5rem .875rem;
        border-radius: var(--radius);
        font-size: .9rem;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        transition: color .15s, background .15s;
    }

    .nav__links a:hover  { color: #fff; background: rgba(255,255,255,.06); }
    .nav__links a.active { color: var(--accent); background: var(--accent-dim); }
    .nav__links svg { width: 16px; height: 16px; flex-shrink: 0; }

    .nav__actions { display: flex; align-items: center; gap: .625rem; }

    .nav__search {
        display: flex;
        align-items: center;
        gap: .625rem;
        padding: 0 .875rem;
        height: 40px;
        width: 280px;
        border-radius: var(--radius);
        background: var(--surface);
        border: 1px solid var(--border);
        cursor: pointer;
        transition: border-color .2s, background .2s;
    }

    .nav__search:hover { border-color: rgba(255,255,255,.14); background: rgba(255,255,255,.06); }
    .nav__search svg { width: 15px; height: 15px; color: #64748b; flex-shrink: 0; }
    .nav__search span { font-size: .875rem; color: #475569; pointer-events: none; }

    .nav__btn {
        width: 40px; height: 40px;
        border-radius: var(--radius);
        background: var(--surface);
        border: 1px solid var(--border);
        color: #fff;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: background .2s, border-color .2s;
    }

    .nav__btn:hover { background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.14); }
    .nav__btn svg { width: 17px; height: 17px; }

    .nav__divider { width: 1px; height: 24px; background: var(--border); }

    .nav__account {
        display: flex;
        align-items: center;
        gap: .5rem;
        padding: 0 1rem;
        height: 40px;
        border-radius: var(--radius);
        background: var(--accent);
        border: none;
        color: #fff;
        font-weight: 700;
        font-size: .875rem;
        text-decoration: none;
        cursor: pointer;
        transition: opacity .15s, box-shadow .15s;
    }

    .nav__account:hover { opacity: .88; box-shadow: 0 4px 20px rgba(153,0,255,.3); }
    .nav__account svg { width: 16px; height: 16px; }

    .nav__hamburger {
        display: none;
        width: 40px; height: 40px;
        border-radius: var(--radius);
        background: var(--surface);
        border: 1px solid var(--border);
        cursor: pointer;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 5px;
        margin-left: auto;
        flex-shrink: 0;
        transition: background .2s, border-color .2s;
    }

    .nav__hamburger:hover { background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.14); }

    .nav__hamburger span {
        display: block;
        width: 18px; height: 1.5px;
        background: #fff;
        border-radius: 2px;
        transition: transform .25s, opacity .25s, width .25s;
        transform-origin: center;
    }

    .nav__hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .nav__hamburger.open span:nth-child(2) { opacity: 0; width: 0; }
    .nav__hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    .mob-menu {
        position: fixed;
        top: 64px; left: 0; right: 0; bottom: 0;
        background: rgba(8,8,8,0.97);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        z-index: 998;
        display: flex;
        flex-direction: column;
        padding: 1rem 1.25rem 2rem;
        gap: .3rem;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(-6px);
        transition: opacity .22s ease, transform .22s ease, visibility 0s linear .22s;
    }

    .mob-menu.open {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0);
        transition: opacity .22s ease, transform .22s ease, visibility 0s linear 0s;
    }

    .mob-menu__link {
        display: flex;
        align-items: center;
        gap: .875rem;
        padding: .825rem 1rem;
        border-radius: 12px;
        font-size: .9375rem;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        border: 1px solid transparent;
        transition: color .15s, background .15s, border-color .15s;
    }

    .mob-menu__link svg { width: 20px; height: 20px; flex-shrink: 0; }
    .mob-menu__link:hover  { color: #fff; background: rgba(255,255,255,.05); border-color: var(--border); }
    .mob-menu__link.active { color: var(--accent); background: var(--accent-dim); border-color: rgba(153,0,255,.15); }

    .mob-menu__divider { height: 1px; background: var(--border); margin: .5rem 0; }

    .mob-menu__bottom {
        display: flex;
        flex-direction: column;
        gap: .625rem;
        margin-top: auto;
        padding-top: 1rem;
    }

    .mob-menu__search {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .875rem 1rem;
        border-radius: 12px;
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--muted);
        font-size: .9375rem;
        cursor: pointer;
        transition: border-color .2s, background .2s;
    }

    .mob-menu__search svg { width: 18px; height: 18px; flex-shrink: 0; }
    .mob-menu__search:hover { border-color: rgba(255,255,255,.14); background: rgba(255,255,255,.06); }

    .mob-menu__account {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .625rem;
        padding: .9375rem 1rem;
        border-radius: 12px;
        background: var(--accent);
        border: none;
        color: #fff;
        font-weight: 700;
        font-size: .9375rem;
        text-decoration: none;
        cursor: pointer;
        transition: opacity .15s, box-shadow .15s;
    }

    .mob-menu__account:hover { opacity: .88; box-shadow: 0 4px 24px rgba(153,0,255,.3); }
    .mob-menu__account svg { width: 18px; height: 18px; }

    .search-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.75);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        z-index: 9999;
        align-items: flex-start;
        justify-content: center;
        padding-top: 6vh;
        opacity: 0;
        transition: opacity .25s;
    }

    .search-modal.open { display: flex; opacity: 1; }

    .search-modal__box {
        width: min(680px, 92vw);
        background: #141414;
        border: 1px solid var(--border);
        border-radius: 14px;
        max-height: 78vh;
        display: flex;
        flex-direction: column;
        transform: translateY(-12px);
        transition: transform .25s;
    }

    .search-modal.open .search-modal__box { transform: translateY(0); }

    .search-modal__head {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: 1.125rem 1.25rem;
        border-bottom: 1px solid var(--border);
    }

    .search-modal__head svg { width: 18px; height: 18px; color: #64748b; flex-shrink: 0; }

    .search-modal__input {
        flex: 1;
        background: none;
        border: none;
        outline: none;
        color: #fff;
        font-size: .9375rem;
    }

    .search-modal__input::placeholder { color: #475569; }

    .search-modal__close {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        padding: .375rem;
        border-radius: 6px;
        display: flex;
        transition: color .15s;
    }

    .search-modal__close:hover { color: #fff; }
    .search-modal__close svg { width: 18px; height: 18px; }

    .search-modal__body { overflow-y: auto; padding: .875rem 1.25rem 1.25rem; }

    .search-results { display: flex; flex-direction: column; gap: .375rem; }

    .result-item {
        display: flex;
        align-items: center;
        gap: .875rem;
        padding: .75rem;
        border-radius: var(--radius);
        border: 1px solid transparent;
        background: var(--surface);
        text-decoration: none;
        transition: all .18s;
    }

    .result-item:hover { background: rgba(255,255,255,.06); border-color: rgba(153,0,255,.2); transform: translateX(3px); }

    .result-item__img, .result-item__thumb {
        width: 48px; height: 48px;
        border-radius: 8px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .result-item__thumb {
        background: var(--accent-dim);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
    }

    .result-item__thumb svg { width: 22px; height: 22px; }
    .result-item__name  { color: #fff; font-weight: 600; font-size: .875rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .result-item__price { color: var(--muted); font-size: .8125rem; margin-top: 2px; }
    .result-item__stock { color: var(--accent); font-size: .8rem; margin-left: auto; white-space: nowrap; }

    .no-results { text-align: center; padding: 2.5rem 1rem; color: var(--muted); display: none; }
    .no-results svg { width: 40px; height: 40px; opacity: .4; margin-bottom: .75rem; display: block; margin-inline: auto; }

    .hidden { display: none !important; }

    @media (max-width: 1300px) {
        .nav { gap: 1.25rem; padding: 0 1.5rem; }
        .nav__search { width: 220px; }
        .nav__links a { padding: .5rem .625rem; }
    }

    @media (max-width: 1180px) {
        .nav { gap: 1rem; padding: 0 1.25rem; }
        .nav__search { width: 180px; }
        .nav__links a { padding: .5rem .5rem; font-size: .825rem; gap: .35rem; }
        .nav__links svg { width: 14px; height: 14px; }
        .nav__actions { gap: .5rem; }
    }

    @media (max-width: 1080px) {
        .nav__search { width: 40px; padding: 0; justify-content: center; }
        .nav__search span { display: none; }
        .nav__search svg { color: var(--muted); }
        .nav__links a { padding: .5rem .4rem; font-size: .8rem; }
    }

    @media (max-width: 979px) {
        .nav__links,
        .nav__search,
        .nav__divider,
        .nav__account,
        .nav__btn { display: none; }
        .nav__hamburger { display: flex; }
    }
</style>

<nav class="nav" id="navbar">
    <a href="{{ '/' | shopUrl }}"><img src="{{ shop.image_url }}" class="nav__logo" alt="{{ shop.name }}"></a>

    <ul class="nav__links">
        {% for link in global.components.navbar.left_links %}
        <li><a href="{{ link.link | shopUrl }}" target="{{ '_blank' if link.new_tab }}" data-path="{{ link.link }}">
            {{ link.text }}
        </a></li>
        {% endfor %}
        {% for link in global.components.navbar.right_links %}
        <li><a href="{{ link.link | shopUrl }}" target="{{ '_blank' if link.new_tab }}" data-path="{{ link.link }}">
            {{ link.text }}
        </a></li>
        {% endfor %}
    </ul>

    <div class="nav__actions">
        <div class="nav__search" id="searchTrigger">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <span>Search products...</span>
        </div>
        {% if not global.components.navbar.hide_cart %}
        <a href="{{ '/cart' | shopUrl }}" class="nav__btn" aria-label="Cart">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
        </a>
        {% endif %}
        <div class="nav__divider"></div>
        {% if not global.components.navbar.hide_customer_dashboard %}
            {% if shop_customer %}
                <a href="{{ '/customer/dashboard' | shopUrl }}" class="nav__account">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    My Account
                </a>
            {% else %}
                <button class="nav__account" type="button" @click="appCustomer.loginOrRedirect()">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Login
                </button>
            {% endif %}
        {% endif %}
    </div>

    <button class="nav__hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
    </button>
</nav>

<div class="mob-menu" id="mobMenu" aria-hidden="true">
    {% for link in global.components.navbar.left_links %}
    <a href="{{ link.link | shopUrl }}" class="mob-menu__link" target="{{ '_blank' if link.new_tab }}" data-path="{{ link.link }}">
        {{ link.text }}
    </a>
    {% endfor %}
    {% for link in global.components.navbar.right_links %}
    <a href="{{ link.link | shopUrl }}" class="mob-menu__link" target="{{ '_blank' if link.new_tab }}" data-path="{{ link.link }}">
        {{ link.text }}
    </a>
    {% endfor %}

    <div class="mob-menu__divider"></div>

    <div class="mob-menu__bottom">
        <div class="mob-menu__search" id="mobSearchTrigger">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            Search products...
        </div>
        {% if not global.components.navbar.hide_customer_dashboard %}
            {% if shop_customer %}
                <a href="{{ '/customer/dashboard' | shopUrl }}" class="mob-menu__account">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    My Account
                </a>
            {% else %}
                <button class="mob-menu__account" type="button" @click="appCustomer.loginOrRedirect()">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Login
                </button>
            {% endif %}
        {% endif %}
    </div>
</div>

<div class="search-modal" id="searchModal">
    <div class="search-modal__box">
        <div class="search-modal__head">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input class="search-modal__input" id="searchInput" placeholder="Search for products..." autocomplete="off">
            <button class="search-modal__close" id="closeSearch">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="search-modal__body">
            <div class="search-results" id="searchResults">
                {% for product in products %}
                <a href="{{ '/product/' ~ product.slug | shopUrl }}" class="result-item" data-name="{{ product.title | lower }}">
                    {% if product.image_url %}
                        <img src="{{ product.image_url }}" class="result-item__img" alt="{{ product.title }}">
                    {% else %}
                        <div class="result-item__thumb">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                        </div>
                    {% endif %}
                    <div style="flex:1;min-width:0">
                        <div class="result-item__name">{{ product.title }}</div>
                        <div class="result-item__price">{{ product.price_range }}</div>
                    </div>
                    <div class="result-item__stock">
                        {% if product.in_stock %}In Stock{% else %}Out of Stock{% endif %}
                    </div>
                </a>
                {% endfor %}
            </div>
            <div class="no-results" id="noResults">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <p>No products found</p>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    var navbar = document.getElementById('navbar');
    var rafPending = false;
    var isScrolled = false;

    function getScrollTop() {
        if (window.scrollY > 0) return window.scrollY;
        if (window.pageYOffset > 0) return window.pageYOffset;
        if (document.documentElement.scrollTop > 0) return document.documentElement.scrollTop;
        if (document.body.scrollTop > 0) return document.body.scrollTop;
        return 0;
    }

    function applyScroll() {
        rafPending = false;
        var shouldScroll = getScrollTop() > 40;
        if (shouldScroll === isScrolled) return;
        isScrolled = shouldScroll;
        navbar.classList.toggle('scrolled', isScrolled);
    }

    function onScroll() {
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(applyScroll);
    }

    var scrollOpts = { passive: true };
    window.addEventListener('scroll', onScroll, scrollOpts);
    document.addEventListener('scroll', onScroll, scrollOpts);
    setInterval(onScroll, 150);
    applyScroll();

    var path = window.location.pathname;
    var hash = window.location.hash;
    var matched = false;

    document.querySelectorAll('[data-path]').forEach(function(a) {
        var dp = a.dataset.path;
        if (dp === '__external') return;
        var active = false;
        if (dp === '/#products') {
            active = path === '/' && hash === '#products';
        } else if (dp !== '/') {
            active = path.startsWith(dp);
        }
        if (active) { a.classList.add('active'); matched = true; }
    });

    if (!matched) {
        document.querySelectorAll('[data-path="/"]').forEach(function(a) { a.classList.add('active'); });
    }

    var hamburger = document.getElementById('hamburger');
    var mobMenu   = document.getElementById('mobMenu');

    function openMenu() {
        hamburger.classList.add('open');
        hamburger.setAttribute('aria-expanded', 'true');
        mobMenu.classList.add('open');
        mobMenu.setAttribute('aria-hidden', 'false');
    }

    function closeMenu() {
        hamburger.classList.remove('open');
        hamburger.setAttribute('aria-expanded', 'false');
        mobMenu.classList.remove('open');
        mobMenu.setAttribute('aria-hidden', 'true');
    }

    hamburger.addEventListener('click', function() {
        if (mobMenu.classList.contains('open')) { closeMenu(); } else { openMenu(); }
    });
    mobMenu.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeMenu); });

    var modal     = document.getElementById('searchModal');
    var input     = document.getElementById('searchInput');
    var resultsEl = document.getElementById('searchResults');
    var noRes     = document.getElementById('noResults');
    var allItems  = Array.from(resultsEl.querySelectorAll('.result-item'));

    function openSearch() {
        closeMenu();
        modal.classList.add('open');
        setTimeout(function() { input.focus(); }, 80);
    }

    function closeSearch() {
        modal.classList.remove('open');
        input.value = '';
        filter('');
    }

    document.getElementById('searchTrigger').addEventListener('click', openSearch);
    document.getElementById('mobSearchTrigger').addEventListener('click', openSearch);
    document.getElementById('closeSearch').addEventListener('click', closeSearch);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeSearch(); });

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            if (modal.classList.contains('open')) { closeSearch(); }
            else if (mobMenu.classList.contains('open')) { closeMenu(); }
        }
    });

    var filterTimer = null;
    input.addEventListener('input', function(e) {
        clearTimeout(filterTimer);
        var val = e.target.value;
        filterTimer = setTimeout(function() { filter(val); }, 120);
    });

    function filter(q) {
        var term = q.toLowerCase().trim();
        var count = 0;
        allItems.forEach(function(el) {
            var match = !term || el.dataset.name.includes(term);
            el.classList.toggle('hidden', !match);
            if (match) count++;
        });
        var empty = !count && !!term;
        noRes.style.display     = empty ? 'block' : 'none';
        resultsEl.style.display = empty ? 'none'  : '';
    }
})();
</script>

</nav>