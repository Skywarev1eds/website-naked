<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">

<style>
  .bx-faq { padding: 80px 0; }

  .bx-faq__container { max-width: 800px; margin: 0 auto; padding: 0 24px; }

  .bx-faq__header { text-align: center; margin-bottom: 48px; }

  .bx-faq__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(153,0,255,0.1);
    border: 1px solid rgba(153,0,255,0.3);
    border-radius: 999px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 600;
    color: #9900ff;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .bx-faq__title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px;
    line-height: 1.15;
  }

  .bx-faq__subtitle {
    font-size: 15px;
    color: rgba(255,255,255,0.45);
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .bx-faq__list { display: flex; flex-direction: column; gap: 10px; }

  .bx-faq__item {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .bx-faq__item.open { border-color: rgba(153,0,255,0.35); }

  .bx-faq__q {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: #fff;
  }

  .bx-faq__dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #9900ff;
    flex-shrink: 0;
  }

  .bx-faq__q-text {
    flex: 1;
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    line-height: 1.4;
  }

  .bx-faq__chevron {
    width: 18px; height: 18px;
    color: rgba(255,255,255,0.4);
    flex-shrink: 0;
    transition: transform 0.25s ease, color 0.2s ease;
  }

  .bx-faq__item.open .bx-faq__chevron {
    transform: rotate(180deg);
    color: #9900ff;
  }

  .bx-faq__a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.2s ease;
  }

  .bx-faq__item.open .bx-faq__a { max-height: 600px; }

  .bx-faq__a-inner {
    padding: 0 20px 18px 38px;
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    line-height: 1.75;
  }
</style>

<div class="bx-faq">
  <div class="bx-faq__container">

    <div class="bx-faq__header">
      {% if properties.headline %}
      <div>
        <span class="bx-faq__badge" data-dsr>{{ properties.headline | renderString }}</span>
      </div>
      {% endif %}
      {% if properties.title %}
      <h2 class="bx-faq__title" data-dsr>{{ properties.title | renderString }}</h2>
      {% endif %}
      {% if properties.subtitle %}
      <p class="bx-faq__subtitle" data-dsr>{{ properties.subtitle | renderString }}</p>
      {% endif %}
    </div>

    <div class="bx-faq__list">
      {% for item in properties.items %}
      <div class="bx-faq__item" data-dsr>
        <button class="bx-faq__q" type="button" onclick="bxFaqToggle(this)">
          <span class="bx-faq__dot"></span>
          <span class="bx-faq__q-text">{{ item.question | renderString }}</span>
          <svg class="bx-faq__chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="bx-faq__a">
          <div class="bx-faq__a-inner">{{ item.answer | renderString }}</div>
        </div>
      </div>
      {% endfor %}
    </div>

  </div>
</div>

<script>
function bxFaqToggle(btn) {
  var item = btn.closest('.bx-faq__item');
  var isOpen = item.classList.contains('open');
  document.querySelectorAll('.bx-faq__item.open').forEach(function(el) { el.classList.remove('open'); });
  if (!isOpen) { item.classList.add('open'); }
}
</script>

</section>
