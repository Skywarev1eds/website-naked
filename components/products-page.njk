{% set title_to_use = properties.default_title %}
{% if category and properties.category_title %}
  {% set title_to_use = properties.category_title %}
{% endif %}
{% set subtitle_to_use = properties.default_subtitle %}
{% if category and properties.category_subtitle %}
  {% set subtitle_to_use = properties.category_subtitle %}
{% endif %}

<section
  class="component"
  data-component-id="{{ componentId }}"
  x-data="{
    openGroupModalId: null,
    filtersModalOpen: false,
    openGroupModal(id) {
      this.openGroupModalId = id;
      document.body.style.overflow = 'hidden';
    },
    closeGroupModal() {
      this.openGroupModalId = null;
      document.body.style.overflow = 'auto';
    },
    openFiltersModal() {
      this.filtersModalOpen = true;
      document.body.style.overflow = 'hidden';
    },
    closeFiltersModal() {
      this.filtersModalOpen = false;
      document.body.style.overflow = 'auto';
    },
    submitForm() {
      const form = event.target;
      const inputs = form.querySelectorAll('input, select, textarea');
      inputs.forEach(input => {
        if (!input.value) {
          input.disabled = true;
        }
      });
      form.submit();
    }
  }"
>
  <div class="container mx-auto">
    <div class="py-24 lg:py-32 relative">
      <div class="m-auto absolute inset-0 -z-10 aspect-square rounded-full blur-[200px] bg-accent-500/50 max-w-4xl -translate-y-1/2 w-[65%]" aria-hidden="true"></div>
      {% if properties.headline or title_to_use or subtitle_to_use %}
        <div class="flex flex-col gap-4 mb-8 text-center relative">
          {% if properties.headline %}
            <div>
              <span class="inline-block px-6 py-2 rounded-full border-2 border-white/5 bg-white/5 text-accent-100 text-sm font-semibold hover:translate-y-[-2px] transition-transform duration-300 ease-in-out" data-dsr>
                {{ properties.headline | renderString }}
              </span>
            </div>
          {% endif %}
          {% if title_to_use %}
            <h1 class="text-4xl lg:text-5xl font-bold text-t-primary" data-dsr>
              {{ title_to_use | renderString }}
            </h1>
          {% endif %}
          {% if subtitle_to_use %}
            <p class="text-base text-t-primary/50" data-dsr>
              {{ subtitle_to_use | renderString }}
            </p>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="lg:hidden px-4 mb-6" data-dsr>
      <button
        x-on:click="openFiltersModal"
        class="flex items-center justify-center w-full gap-4 border-2 px-8 py-2.5 rounded-full font-semibold bg-accent-500 border-accent-500 text-t-accent hover:bg-accent-500/50 hover:text-t-primary transition-colors duration-300 ease-in-out"
      >
        <span>Filters</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><path fill="currentColor" d="M11 20q-.425 0-.712-.288T10 19v-6L4.2 5.6q-.375-.5-.112-1.05T5 4h14q.65 0 .913.55T19.8 5.6L14 13v6q0 .425-.288.713T13 20z"/></svg>
      </button>
    </div>

    <div class="px-4 mb-16 lg:mb-32">
      <div class="grid lg:grid-cols-[280px_1fr] gap-8">
        <aside class="hidden lg:block" data-dsr>
          <div class="sticky top-8 rounded-xl bg-white/5 border-2 border-white/5 p-4 md:p-5 lg:p-6 text-t-primary">
            <form x-on:submit.prevent="submitForm" class="space-y-6">
              <div>
                <label class="block mb-2 font-medium">
                  Categories
                </label>
                <div class="space-y-1">
                  <a
                    href="{{ '/products' | shopUrl }}"
                    class="text-t-primary rounded-lg py-2.5 px-4 block w-full border border-transparent transition hover:bg-white/[0.025] {% if not category %}bg-white/5 !border-white/5{% endif %}"
                  >
                    All Categories
                  </a>
                  {% for cat in category_links %}
                    <a
                      href="{{ cat.url }}"
                      class="text-t-primary rounded-lg py-2.5 px-4 block w-full border border-transparent transition hover:bg-white/[0.025] {% if category and category.id == cat.id %}bg-white/5 !border-white/5{% endif %}"
                      style="padding-left: {{ (cat.depth * 12 + 12) }}px"
                    >
                      {{ cat.name }}
                    </a>
                  {% endfor %}
                </div>
              </div>
              <div>
                <label for="filters[keyword]" class="block mb-2 font-medium">
                  Keyword
                </label>
                <input
                  type="text"
                  name="filters[keyword]"
                  id="filters[keyword]"
                  value="{{ filters.keyword }}"
                  placeholder="Search..."
                  class="bg-white/5 text-t-primary rounded-lg py-2.5 px-4 w-full border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                />
              </div>
              <div>
                <label class="block mb-2 font-medium">
                  Price Range
                </label>
                <input type="hidden" name="filters[price][currency]" :value="appCurrency.currency" />
                <div class="grid grid-cols-2 gap-3">
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][from]"
                      min="0"
                      value="{{ filters.price.from }}"
                      placeholder="Min"
                      class="bg-white/5 text-t-primary rounded-lg py-2.5 px-4 pr-10 w-full border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                    />
                    <span class="absolute top-1/2 right-4 -translate-y-1/2 text-t-primary/50 text-sm">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                  <div class="relative">
                    <input
                      type="number"
                      name="filters[price][to]"
                      min="0"
                      value="{{ filters.price.to }}"
                      placeholder="Max"
                      class="bg-white/5 text-t-primary rounded-lg py-2.5 px-4 pr-10 w-full border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                    />
                    <span class="absolute top-1/2 right-4 -translate-y-1/2 text-t-primary/50 text-sm">
                      <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                    </span>
                  </div>
                </div>
              </div>
              <div class="space-y-4">
                <button
                  type="submit"
                  class="flex items-center justify-center w-full gap-4 border-2 px-8 py-2.5 rounded-full font-semibold bg-accent-500 border-accent-500 text-t-accent hover:bg-accent-500/50 hover:text-t-primary transition-colors duration-300 ease-in-out"
                >
                  <span>Apply</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M16.15 13H5q-.425 0-.712-.288T4 12t.288-.712T5 11h11.15L13.3 8.15q-.3-.3-.288-.7t.288-.7q.3-.3.713-.312t.712.287L19.3 11.3q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.575 4.575q-.3.3-.712.288t-.713-.313q-.275-.3-.288-.7t.288-.7z"/></svg>
                </button>
                <a
                  href="{{ '/products' | shopUrl }}"
                  class="flex items-center justify-center w-full gap-4 border-2 px-8 py-2.5 rounded-full font-semibold bg-white/5 border-white/5 text-t-primary hover:bg-white/10 hover:text-t-primary transition-colors duration-300 ease-in-out"
                >
                  <span>Reset</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M12 22q-1.875 0-3.512-.712t-2.85-1.925t-1.925-2.85T3 13h2q0 2.925 2.038 4.963T12 20t4.963-2.037T19 13t-2.037-4.962T12 6h-.15l1.55 1.55L12 9L8 5l4-4l1.4 1.45L11.85 4H12q1.875 0 3.513.713t2.85 1.925t1.925 2.85T21 13t-.712 3.513t-1.925 2.85t-2.85 1.925T12 22"/></svg>
                </a>
              </div>
            </form>
          </div>
        </aside>

        <div class="min-w-0">
          {% if items.length > 0 %}
            <div class="flex flex-wrap gap-4 w-full {{ 'justify-center' if properties.centered }}">
              {% for item in items %}
                {% if item.type == 'group' or not item.group_id %}
                  <div class="w-full sm:w-[calc((100%-1rem)/2)] xl:w-[calc((100%-2rem)/3)]" data-dsr>
                    {% render_snippet "product-card.njk", product=item %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% else %}
            <div class="text-center" data-dsr>
              <svg xmlns="http://www.w3.org/2000/svg" class="size-24 mx-auto text-t-primary/30 mb-4" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M11 18q-.425 0-.712-.288T10 17t.288-.712T11 16h2q.425 0 .713.288T14 17t-.288.713T13 18zm-4-5q-.425 0-.712-.288T6 12t.288-.712T7 11h10q.425 0 .713.288T18 12t-.288.713T17 13zM4 8q-.425 0-.712-.288T3 7t.288-.712T4 6h16q.425 0 .713.288T21 7t-.288.713T20 8z"/></svg>
              <p class="text-t-primary/70 text-lg">
                No products found matching your criteria.
              </p>
            </div>
          {% endif %}

          {% if items_paginator.last_page > 1 %}
            <div class="mt-8">
              {% render_snippet "pagination.njk", paginator=items_paginator %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <div
    x-cloak
    x-show="filtersModalOpen"
    class="fixed inset-0 z-50 overflow-y-auto lg:hidden"
  >
    <div class="flex items-center justify-center min-h-screen px-4 text-center">
      <div
        x-show="filtersModalOpen"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        @click="closeFiltersModal()"
        class="fixed inset-0 transition-opacity bg-black/75"
      ></div>
      <div
        x-show="filtersModalOpen"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        class="inline-block w-full max-w-lg p-6 my-8 overflow-hidden text-left align-middle transition-all transform border-2 border-white/5 rounded-xl bg-background/75 backdrop-blur-lg text-t-primary max-h-[85vh] overflow-y-auto"
      >
        <div class="flex items-start justify-between gap-4 mb-6">
          <h3 class="text-xl font-bold">
            Filters
          </h3>
          <button @click="closeFiltersModal()" class="text-t-primary focus:outline-none hover:text-accent">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
          </button>
        </div>
        <form x-on:submit.prevent="submitForm" class="space-y-6">
          <div>
            <label class="block mb-2 font-medium">
              Categories
            </label>
            <div class="space-y-1">
              <a
                href="{{ '/products' | shopUrl }}"
                class="text-t-primary rounded-lg py-2.5 px-4 block w-full border border-transparent transition hover:bg-white/[0.025] {% if not category %}bg-white/5 !border-white/5{% endif %}"
              >
                All Categories
              </a>
              {% for cat in category_links %}
                <a
                  href="{{ cat.url }}"
                  class="text-t-primary rounded-lg py-2.5 px-4 block w-full border border-transparent transition hover:bg-white/[0.025] {% if category and category.id == cat.id %}bg-white/5 !border-white/5{% endif %}"
                  style="padding-left: {{ (cat.depth * 12 + 12) }}px"
                >
                  {{ cat.name }}
                </a>
              {% endfor %}
            </div>
          </div>
          <div>
            <label for="filters[keyword]" class="block mb-2 font-medium">
              Keyword
            </label>
            <input
              type="text"
              name="filters[keyword]"
              id="filters[keyword]"
              value="{{ filters.keyword }}"
              placeholder="Search..."
              class="bg-white/5 text-t-primary rounded-lg py-2.5 px-4 w-full border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
            />
          </div>
          <div>
            <label class="block mb-2 font-medium">
              Price Range
            </label>
            <input type="hidden" name="filters[price][currency]" :value="appCurrency.currency" />
            <div class="grid grid-cols-2 gap-3">
              <div class="relative">
                <input
                  type="number"
                  name="filters[price][from]"
                  min="0"
                  value="{{ filters.price.from }}"
                  placeholder="Min"
                  class="bg-white/5 text-t-primary rounded-lg py-2.5 px-4 pr-10 w-full border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                />
                <span class="absolute top-1/2 right-4 -translate-y-1/2 text-t-primary/50 text-sm">
                  <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                </span>
              </div>
              <div class="relative">
                <input
                  type="number"
                  name="filters[price][to]"
                  min="0"
                  value="{{ filters.price.to }}"
                  placeholder="Max"
                  class="bg-white/5 text-t-primary rounded-lg py-2.5 px-4 pr-10 w-full border border-white/5 focus:border-accent-500 focus:ring-1 focus:ring-accent-500 focus:outline-none"
                />
                <span class="absolute top-1/2 right-4 -translate-y-1/2 text-t-primary/50 text-sm">
                  <span x-text="window.currencySymbols[appCurrency.currency.toLowerCase()]"></span>
                </span>
              </div>
            </div>
          </div>
          <div class="space-y-4">
            <button
              type="submit"
              class="flex items-center justify-center w-full gap-4 border-2 px-8 py-2.5 rounded-full font-semibold bg-accent-500 border-accent-500 text-t-accent hover:bg-accent-500/50 hover:text-t-primary transition-colors duration-300 ease-in-out"
            >
              <span>Apply</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M16.15 13H5q-.425 0-.712-.288T4 12t.288-.712T5 11h11.15L13.3 8.15q-.3-.3-.288-.7t.288-.7q.3-.3.713-.312t.712.287L19.3 11.3q.15.15.213.325t.062.375t-.062.375t-.213.325l-4.575 4.575q-.3.3-.712.288t-.713-.313q-.275-.3-.288-.7t.288-.7z"/></svg>
            </button>
            <a
              href="{{ '/products' | shopUrl }}"
              class="flex items-center justify-center w-full gap-4 border-2 px-8 py-2.5 rounded-full font-semibold bg-white/5 border-white/5 text-t-primary hover:bg-white/10 hover:text-t-primary transition-colors duration-300 ease-in-out"
            >
              <span>Reset</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M12 22q-1.875 0-3.512-.712t-2.85-1.925t-1.925-2.85T3 13h2q0 2.925 2.038 4.963T12 20t4.963-2.037T19 13t-2.037-4.962T12 6h-.15l1.55 1.55L12 9L8 5l4-4l1.4 1.45L11.85 4H12q1.875 0 3.513.713t2.85 1.925t1.925 2.85T21 13t-.712 3.513t-1.925 2.85t-2.85 1.925T12 22"/></svg>
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>

  {% for item in items %}
    {% if item.type == 'group' %}
      <div
        x-cloak
        x-show="openGroupModalId == '{{ item.id }}'"
        class="fixed inset-0 z-50 overflow-y-auto"
      >
        <div class="flex items-end justify-center min-h-screen px-2 text-center md:items-center md:px-4">
          <div
            x-cloak
            @click="closeGroupModal"
            x-show="openGroupModalId == '{{ item.id }}'"
            x-transition:enter="transition ease-out duration-300 transform"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200 transform"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 transition-opacity bg-black/75"
          ></div>
          <div
            x-cloak
            x-show="openGroupModalId == '{{ item.id }}'"
            x-transition:enter="transition ease-out duration-300 transform"
            x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
            x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
            x-transition:leave="transition ease-in duration-200 transform"
            x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
            x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
            class="inline-block w-full p-4 my-20 overflow-hidden text-left transition-all transform border-2 border-white/5 rounded-xl bg-background/75 backdrop-blur-lg text-t-primary sm:p-8 {{ 'max-w-full lg:max-w-7xl' if global.properties.group_modal_product_card_type == 'grid' else 'max-w-xl lg:max-w-3xl' }}"
          >
            <div class="flex items-start justify-between gap-4 mb-4 sm:mb-8">
              <h3 class="text-xl font-bold truncate">
                {{ item.name }}
              </h3>

              <button @click="closeGroupModal" class="text-t-primary focus:outline-none hover:text-accent">
                <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
              </button>
            </div>

            {% if global.properties.group_modal_product_card_type == 'grid' %}
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                {% for product in item.products %}
                  {% render_snippet "product-card.njk", product=product %}
                {% endfor %}
              </div>
            {% else %}
              <div class="flex flex-col gap-4">
                {% for product in item.products %}
                  {% render_snippet "product-card-horizontal.njk", product=product %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</section>