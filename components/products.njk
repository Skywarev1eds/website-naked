<section
  id="{{ componentId }}"
  class="component"
  data-component-id="{{ componentId }}"
  x-data="{
    searchTerm: '',
    shouldShowItem(el) {
      return this.searchTerm === '' || decodeHtmlEntities(el.dataset.name.toLowerCase()).includes(this.searchTerm.toLowerCase());
    },
    openGroupModalId: null,
    openGroupModal(id) {
      this.openGroupModalId = id;
      document.body.style.overflow = 'hidden';
    },
    closeGroupModal() {
      this.openGroupModalId = null;
      document.body.style.overflow = 'auto';
    }
  }"
>

<style>
  .pcard-section { padding: 80px 0 60px; }

  .pcard-header { text-align: center; margin-bottom: 48px; }

  .pcard-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(153,0,255,0.1);
    border: 1px solid rgba(153,0,255,0.3);
    border-radius: 999px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 600;
    color: #9900ff;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .pcard-badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #9900ff;
    animation: pcard-blink 1.4s ease-in-out infinite;
  }

  .pcard-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    color: #fff;
    margin: 0 0 12px;
    line-height: 1.15;
  }

  .pcard-subtitle {
    font-size: 15px;
    color: rgba(255,255,255,0.45);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .pcard-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
    padding: 0 16px;
  }

  .pcard-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    width: 100%;
    max-width: 340px;
    display: flex;
    flex-direction: column;
    position: relative;
    text-decoration: none;
  }

  .pcard-card:hover {
    transform: translateY(-4px);
    border-color: rgba(153,0,255,0.4);
    box-shadow: 0 8px 40px rgba(153,0,255,0.12), 0 2px 16px rgba(0,0,0,0.4);
  }

  .pcard-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: rgba(255,255,255,0.03);
  }

  .pcard-img-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .pcard-card:hover .pcard-img-wrap img { transform: scale(1.05); }

  .pcard-img-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: rgba(153,0,255,0.5);
  }

  .pcard-stock {
    position: absolute;
    top: 10px; left: 10px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.04em;
  }

  .pcard-stock-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #22c55e;
    animation: pcard-blink 1.4s ease-in-out infinite;
  }

  .pcard-body {
    padding: 16px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .pcard-top-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }

  .pcard-name {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    line-height: 1.35;
    flex: 1;
  }

  .pcard-online-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: rgba(153,0,255,0.12);
    border: 1px solid rgba(153,0,255,0.25);
    border-radius: 999px;
    padding: 2px 8px;
    font-size: 10px;
    font-weight: 600;
    color: #9900ff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .pcard-price-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pcard-from {
    font-size: 12px;
    color: rgba(255,255,255,0.45);
  }

  .pcard-price {
    display: inline-flex;
    align-items: center;
    background: rgba(153,0,255,0.15);
    border: 1px solid rgba(153,0,255,0.3);
    border-radius: 6px;
    padding: 3px 10px;
    font-size: 14px;
    font-weight: 700;
    color: #c060ff;
  }

  .pcard-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 6px;
    padding: 10px 16px;
    background: #9900ff;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.15s, box-shadow 0.15s, transform 0.15s;
    text-decoration: none;
    width: 100%;
  }

  .pcard-btn:hover {
    opacity: 0.88;
    box-shadow: 0 4px 20px rgba(153,0,255,0.35);
    transform: translateY(-1px);
  }

  .pcard-all-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 40px;
    padding: 12px 28px;
    border: 1px solid rgba(153,0,255,0.35);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    color: #9900ff;
    text-decoration: none;
    background: rgba(153,0,255,0.06);
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }

  .pcard-all-link:hover {
    background: rgba(153,0,255,0.14);
    border-color: rgba(153,0,255,0.6);
    transform: translateY(-2px);
  }

  @keyframes pcard-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.35; }
  }

  @media (min-width: 640px)  { .pcard-card { max-width: calc(50% - 10px); } }
  @media (min-width: 1024px) { .pcard-card { max-width: calc(33.33% - 14px); } }
  @media (min-width: 1440px) { .pcard-card { max-width: calc(25% - 15px); } }
</style>

<div class="pcard-section">
  <div class="container mx-auto px-4">

    {% if properties.headline or properties.title or properties.subtitle %}
    <div class="pcard-header">
      {% if properties.headline %}
      <div>
        <span class="pcard-badge" data-dsr>
          <span class="pcard-badge-dot"></span>
          {{ properties.headline | renderString }}
        </span>
      </div>
      {% endif %}
      {% if properties.title %}
      <h2 class="pcard-title" data-dsr>{{ properties.title | renderString }}</h2>
      {% endif %}
      {% if properties.subtitle %}
      <p class="pcard-subtitle" data-dsr>{{ properties.subtitle | renderString }}</p>
      {% endif %}
    </div>
    {% endif %}

    {% if properties.show_searchbar %}
    <div class="flex items-center gap-4 w-full mb-6 bg-white/5 text-accent-200 rounded-xl px-4 cursor-pointer focus-within:ring-2 focus-within:ring-accent-500 max-w-2xl mx-auto" data-dsr>
      <svg xmlns="http://www.w3.org/2000/svg" class="size-5 opacity-50" viewBox="0 0 24 24"><path fill="currentColor" d="M9.5 16q-2.725 0-4.612-1.888T3 9.5t1.888-4.612T9.5 3t4.613 1.888T16 9.5q0 1.1-.35 2.075T14.7 13.3l5.6 5.6q.275.275.275.7t-.275.7t-.7.275t-.7-.275l-5.6-5.6q-.75.6-1.725.95T9.5 16m0-2q1.875 0 3.188-1.312T14 9.5t-1.312-3.187T9.5 5T6.313 6.313T5 9.5t1.313 3.188T9.5 14"/></svg>
      <input x-model="searchTerm" type="text" class="flex-1 py-4 bg-transparent focus:outline-none text-sm" placeholder="Search for products..." />
    </div>
    {% endif %}

    <div
      x-data
      x-init="() => {
        import('https://cdn.jsdelivr.net/npm/@formkit/auto-animate')
          .then(module => module.default($el));
      }"
      class="pcard-grid"
    >
      {% if properties.ids|length == 0 %}
        {% for item in sortedItems %}
          {% if item.type == 'group' or not item.group_id %}
          <div
            x-show="shouldShowItem($el)"
            x-transition
            data-name="{{ item.name | lower | escape }}"
            class="pcard-card"
          >
            <div class="pcard-img-wrap">
              {% if item.image_url %}
                <img src="{{ item.image_url }}" alt="{{ item.name }}" loading="lazy">
              {% else %}
                <div class="pcard-img-placeholder">
                  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                </div>
              {% endif %}
              {% if item.in_stock %}
              <span class="pcard-stock"><span class="pcard-stock-dot"></span> IN STOCK</span>
              {% endif %}
            </div>
            <div class="pcard-body">
              <div class="pcard-top-row">
                <span class="pcard-name">{{ item.name }}</span>
                <span class="pcard-online-badge">● ONLINE</span>
              </div>
              <div class="pcard-price-row">
                <span class="pcard-from">Starting at</span>
                <span class="pcard-price">{{ item.price_range }}</span>
              </div>
              {% if item.type == 'group' %}
                <button type="button" class="pcard-btn" @click="openGroupModal('{{ item.id }}')">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  Buy Now
                </button>
              {% else %}
                <a href="{{ '/product/' ~ item.slug | shopUrl }}" class="pcard-btn">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  Buy Now
                </a>
              {% endif %}
            </div>
          </div>
          {% endif %}
        {% endfor %}
      {% else %}
        {% for item in helpers.components.products.getItemsByIds(sortedItems, properties.ids) %}
        <div
          x-show="shouldShowItem($el)"
          x-transition
          data-name="{{ item.name | lower | escape }}"
          class="pcard-card"
        >
          <div class="pcard-img-wrap">
            {% if item.image_url %}
              <img src="{{ item.image_url }}" alt="{{ item.name }}" loading="lazy">
            {% else %}
              <div class="pcard-img-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
              </div>
            {% endif %}
            {% if item.in_stock %}
            <span class="pcard-stock"><span class="pcard-stock-dot"></span> IN STOCK</span>
            {% endif %}
          </div>
          <div class="pcard-body">
            <div class="pcard-top-row">
              <span class="pcard-name">{{ item.name }}</span>
              <span class="pcard-online-badge">● ONLINE</span>
            </div>
            <div class="pcard-price-row">
              <span class="pcard-from">Starting at</span>
              <span class="pcard-price">{{ item.price_range }}</span>
            </div>
            {% if item.type == 'group' %}
              <button type="button" class="pcard-btn" @click="openGroupModal('{{ item.id }}')">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Buy Now
              </button>
            {% else %}
              <a href="{{ '/product/' ~ item.slug | shopUrl }}" class="pcard-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Buy Now
              </a>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="flex justify-center">
      <a href="{{ '/all-products' | shopUrl }}" class="pcard-all-link">
        All Products
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</div>

{% for group in sortedItems %}
  {% if group.type == 'group' %}
  <div x-show="openGroupModalId == '{{ group.id }}'" class="fixed inset-0 z-50 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen px-2 text-center md:items-center sm:p-0">
      <div x-cloak @click="closeGroupModal" x-show="openGroupModalId == '{{ group.id }}'"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="fixed inset-0 transition-opacity bg-black/75" aria-hidden="true"
      ></div>
      <div x-cloak x-show="openGroupModalId == '{{ group.id }}'"
        x-transition:enter="transition ease-out duration-300 transform"
        x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave="transition ease-in duration-200 transform"
        x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
        x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
        class="inline-block w-full p-4 my-20 overflow-hidden text-left transition-all transform border-2 border-white/5 rounded-xl bg-background/75 backdrop-blur-lg text-t-primary sm:p-8 {{ 'max-w-full lg:max-w-7xl' if global.properties.group_modal_product_card_type == 'grid' else 'max-w-xl lg:max-w-3xl' }}"
      >
        <div class="flex items-start justify-between gap-4 mb-4 sm:mb-8">
          <h3 class="text-xl font-bold truncate">{{ group.name }}</h3>
          <button @click="closeGroupModal" class="text-t-primary focus:outline-none hover:text-accent">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
          </button>
        </div>
        {% if global.properties.group_modal_product_card_type == 'grid' %}
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {% for product in group.products %}
              {% render_snippet "product-card.njk", product=product %}
            {% endfor %}
          </div>
        {% else %}
          <div class="flex flex-col gap-4">
            {% for product in group.products %}
              {% render_snippet "product-card-horizontal.njk", product=product %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
  {% endif %}
{% endfor %}

</section>
