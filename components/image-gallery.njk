{% if properties.items_per_row == 1 %}
  {% set gridClass = 'grid-cols-1' %}
{% elif properties.items_per_row == 2 %}
  {% set gridClass = 'grid-cols-1 md:grid-cols-2' %}
{% elif properties.items_per_row == 3 %}
  {% set gridClass = 'grid-cols-1 md:grid-cols-3' %}
{% elif properties.items_per_row == 4 %}
  {% set gridClass = 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4' %}
{% endif %}

{% set aspectClassMap = {
  'Default': '',
  '1/1': 'aspect-square',
  '4/3': 'aspect-[4/3]',
  '16/9': 'aspect-video'
} %}

<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="container mx-auto flex flex-col px-4 mb-16 lg:mb-32">
    {% if properties.headline or properties.title or properties.subtitle %}
    <div class="flex flex-col gap-4 mb-8 text-center">
      {% if properties.headline %}
      <div>
        <span class="inline-block px-6 py-2 rounded-full border-2 border-white/5 bg-white/5 text-accent-100 text-sm font-semibold hover:translate-y-[-2px] transition-transform duration-300 ease-in-out" data-dsr>
          {{ properties.headline | renderString }}
        </span>
      </div>
      {% endif %}
      {% if properties.title %}
      <h2 class="text-4xl lg:text-5xl font-bold text-t-primary" data-dsr>
        {{ properties.title | renderString }}
      </h2>
      {% endif %}
      {% if properties.subtitle %}
      <p class="text-base text-t-primary/50" data-dsr>
        {{ properties.subtitle | renderString }}
      </p>
      {% endif %}
    </div>
    {% endif %}

    <div class="grid gap-8 {{ gridClass }}">
      {% for image in properties.images %}
      {% set aspectClass = aspectClassMap[properties.aspect_ratio] %}
      <div class="{{ aspectClass }}" data-dsr>
        <img src="{{ image | imageUrl }}" alt="" class="object-scale-down w-full h-full rounded-xl zoomable" loading="lazy">
      </div>
      {% endfor %}
    </div>
  </div>
</section>