<section class="component" data-component-id="{{ componentId }}">
  <div class="container mx-auto py-12 mb-12 lg:mb-24">
    <div class="flex flex-col gap-4 mb-8 px-4 md:flex-row md:items-center md:justify-between">
      <h1 class="text-3xl font-bold text-t-primary md:text-5xl md:!leading-[1.125]" data-dsr>
        {{ product.name }}
      </h1>
      {% if product.status_color or product.status_text %}
        <div class="flex items-center gap-4 md:pr-2 status" data-color="{{ product.status_color }}" data-label="{{ product.status_text }}" data-dsr>
          <div class="relative size-4 rounded-full md:size-6" style="background-color: {{ product.status_color }}">
            <div class="pulsating" style="background-color: {{ product.status_color }}"></div>
          </div>
          <span class="text-base font-bold md:text-lg" style="color: {{ product.status_color }}">
            {{ product.status_text }}
          </span>
        </div>
      {% endif %}
    </div>
    <div class="flex flex-col lg:flex-row">
      <div class="lg:w-3/5 px-4" >
        <div class="mb-8" data-dsr>
          {% if product.image_urls|length > 0 %}
          <div class="splide main">
            <div class="splide__track aspect-product-page-image">
              <ul class="splide__list">
                {% for image in product.image_urls %}
                <li class="splide__slide bg-black/5 border-2 border-white/5 rounded-xl overflow-hidden aspect-product-page-image">
                  <img src="{{ image }}" class="size-full object-product-image" style="{{ 'display: none;' if loop.index > 1 }}" />
                </li>
                {% endfor %}
              </ul>
            </div>
          </div>
          {% elif product.image_url %}
          <div class="bg-b-secondary border-2 border-border">
            <img src="{{ product.image_url }}" class="rounded-xl size-full object-product-image" />
          </div>
          {% endif %}

          {% if product.image_urls|length > 1 %}
          <div class="splide thumbnails mt-4 max-h-[3.375rem] md:max-h-[4.5rem]">
            <div class="splide__track">
              <ul class="splide__list">
                {% for image in product.image_urls %}
                <li class="splide__slide bg-b-secondary !border-2 !border-white/5 p-1 rounded-xl opacity-50 overflow-hidden">
                  <img src="{{ image }}" class="size-full object-product-image" />
                </li>
                {% endfor %}
              </ul>
            </div>
          </div>
          {% endif %}

          {% if not product.image_url and (product.image_urls|length) == 0 %}
          <div class="flex items-center justify-center w-full h-[400px] border-2 border-white/5 bg-black/10 rounded-xl">
            <svg class="size-36 text-accent-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256">
              <path fill="currentColor" d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z" />
            </svg>
          </div>
          {% endif %}
        </div>
        <div x-data="{ activeTab: 'description' }">
          <div class="flex flex-wrap items-center gap-4 mb-4" data-dsr>
            <button type="button" @click="activeTab = 'description'" class="inline-block px-6 py-2 rounded-xl border-2 border-white/5 bg-white/5 text-accent-100 text-base font-medium" :class="`${activeTab != 'description' ? 'opacity-50' : ''}`">
              Description
            </button>
            {% for productTab in product.product_tabs %}
              <button type="button" @click="activeTab = '{{ productTab.slug }}'" class="inline-block px-6 py-2 rounded-xl border-2 border-white/5 bg-white/5 text-accent-100 text-base font-medium" :class="`${activeTab != '{{ productTab.slug }}' ? 'opacity-50' : ''}`">
                {{ productTab.title }}
              </button>
            {% endfor %}
            {% if properties.show_feedbacks %}
            <button type="button" @click="activeTab = 'reviews'" class="inline-block px-6 py-2 rounded-xl border-2 border-white/5 bg-white/5 text-accent-100 text-base font-medium" :class="`${activeTab != 'reviews' ? 'opacity-50' : ''}`">
              Reviews
            </button>
            {% endif %}
          </div>
          <div data-dsr>
            <template x-if="activeTab == 'description'">
              <div class="p-6 rounded-xl border-2 border-white/5 bg-black/5 backdrop-blur-2xl mb-8">
                <div class="text-t-primary editor">
                  {{ product.description | safe }}
                </div>
              </div>
            </template>
            {% for productTab in product.product_tabs %}
              <template x-if="activeTab == '{{ productTab.slug }}'">
                <div class="p-6 rounded-xl border-2 border-white/5 bg-black/5 backdrop-blur-2xl mb-8">
                  <div class="text-t-primary editor">
                    {{ productTab.content | safe }}
                  </div>
                </div>
              </template>
            {% endfor %}
            {% if properties.show_feedbacks %}
            <template x-if="activeTab == 'reviews'">
              <div>
                {% if feedbacks|length > 0 %}
                <div class="flex flex-col gap-4">
                  {% for feedback in feedbacks.slice(0, properties.feedbacks_amount) %}
                    {% render_snippet "feedback-card.njk", feedback=feedback %}
                  {% endfor %}  
                </div>
                {% else %}
                <div class="p-6 rounded-xl border-2 border-white/5 bg-black/5 backdrop-blur-2xl mb-8">
                  <div class="text-t-primary/50">
                    No reviews about this product yet.
                  </div>
                </div>
                {% endif %}
                {% if feedbacks|length > properties.feedbacks_amount %}
                <div class="flex justify-center mt-8">
                  <a href="{{ '/feedback' | shopUrl }}" class="text-accent-500 hover:underline">
                    View All Reviews
                  </a>
                </div>
                {% endif %}
              </div>
            </template>
            {% endif %}
          </div>
        </div>
      </div>
      <div class="lg:w-2/5 px-4">
        <div x-data="productForm">
          <div class="p-6 rounded-xl border-2 border-white/5 bg-white/5 backdrop-blur-2xl mb-4" data-dsr>
            <div class="flex justify-between items-center">
              <div class="flex items-end gap-2">
                <div class="text-3xl text-t-primary">
                  <span x-text="appCurrency.format(totalPrice, '{{ product.currency }}')"></span>
                </div>
                <div class="text-sm text-t-primary/60 mb-0.5">
                  <span x-text="appCurrency.format(unitPrice, '{{ product.currency }}')"></span> each
                </div>
              </div>
              <div>
                {% if product.visibility == 'on_hold' %}
                  <span class="text-t-primary">
                    Product On Hold
                  </span>
                {% else %}
                  <div x-show="activeVariant in product.variants">
                    <span x-show="product.variants[activeVariant].stock > 0 || product.variants[activeVariant].stock === -1" class="text-t-primary">
                      <span x-show="product.variants[activeVariant].stock === -1" class="inline-flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="text-accent-500 size-5" fill="currentColor" viewBox="0 0 256 256"><path d="M248,128a56,56,0,0,1-95.6,39.6l-.33-.35L92.12,99.55a40,40,0,1,0,0,56.9l8.52-9.62a8,8,0,1,1,12,10.61l-8.69,9.81-.33.35a56,56,0,1,1,0-79.2l.33.35,59.95,67.7a40,40,0,1,0,0-56.9l-8.52,9.62a8,8,0,1,1-12-10.61l8.69-9.81.33-.35A56,56,0,0,1,248,128Z"></path></svg>
                        In Stock
                      </span>
                      <span x-show="product.variants[activeVariant].stock > 0 && !product.hide_stock_count" x-text="product.variants[activeVariant].stock + ' In Stock'"></span>
                      <span x-show="product.variants[activeVariant].stock > 0 && product.hide_stock_count">In Stock</span>
                    </span>
                    <span x-show="product.variants[activeVariant].stock === 0" x-cloak class="text-t-primary">
                      Out of Stock
                    </span>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>

          {% if product.category_id or product.product_badges.page|length > 0 %}
            <div class="badges flex items-center gap-3 flex-wrap" data-dsr>
              {% if product.category_id %}
                <a href="{{ product.category.url }}" class="flex items-center gap-2 bg-accent-500 text-t-accent text-sm font-semibold px-3 py-1.5 rounded-lg" >
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M5 11q-.825 0-1.412-.587T3 9V5q0-.825.588-1.412T5 3h4q.825 0 1.413.588T11 5v4q0 .825-.587 1.413T9 11zm0 10q-.825 0-1.412-.587T3 19v-4q0-.825.588-1.412T5 13h4q.825 0 1.413.588T11 15v4q0 .825-.587 1.413T9 21zm10-10q-.825 0-1.412-.587T13 9V5q0-.825.588-1.412T15 3h4q.825 0 1.413.588T21 5v4q0 .825-.587 1.413T19 11zm0 10q-.825 0-1.412-.587T13 19v-4q0-.825.588-1.412T15 13h4q.825 0 1.413.588T21 15v4q0 .825-.587 1.413T19 21zM5 9h4V5H5zm10 0h4V5h-4zm0 10h4v-4h-4zM5 19h4v-4H5zM9 9"/></svg>
                  {{ product.category.name }}
                </a>
              {% endif %}
              {% for productBadge in product.product_badges.page %}
                <div class="flex items-center gap-2 bg-accent-500 text-t-accent text-sm font-semibold px-3 py-1.5 rounded-lg" style="background-color: {{ productBadge.color }}" data-text="{{ productBadge.label }}" data-color="{{ productBadge.color }}">
                  {% if productBadge.icon %}
                    <i class="{{ productBadge.icon }} fa-fw"></i>
                  {% endif %}
                  {{ productBadge.label }}
                </div>
              {% endfor %}
            </div>
          {% endif %}
          
          <div class="mt-4">
            {% render_snippet "product-form.njk", product=product %}
          </div>

          {% if 'sales' in liveStats or 'views' in liveStats %}
            <div class="flex flex-col gap-3 sm:gap-1 p-6 rounded-xl border-2 border-white/5 bg-black/5 backdrop-blur-2xl text-t-primary/50 mt-8" data-dsr>
              {% if 'views' in liveStats %}
                <div class="flex items-center gap-3 sm:gap-1">
                  <span class="w-6 sm:w-5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-5 sm:size-4 text-accent-400" viewBox="0 0 24 24"><path fill="currentColor" d="M12 16q1.875 0 3.188-1.312T16.5 11.5t-1.312-3.187T12 7T8.813 8.313T7.5 11.5t1.313 3.188T12 16m0-1.8q-1.125 0-1.912-.788T9.3 11.5t.788-1.912T12 8.8t1.913.788t.787 1.912t-.787 1.913T12 14.2m0 4.8q-3.35 0-6.113-1.8t-4.362-4.75q-.125-.225-.187-.462t-.063-.488t.063-.488t.187-.462q1.6-2.95 4.363-4.75T12 4t6.113 1.8t4.362 4.75q.125.225.188.463t.062.487t-.062.488t-.188.462q-1.6 2.95-4.362 4.75T12 19"/></svg>
                  </span>
                  <p>
                    <span class="font-semibold">{{ liveStats.views }}</span>
                    {{ 'person is' if liveStats.views == 1 else 'people are' }} currently viewing this product.
                  </p>
                </div>
              {% endif %}
              {% if 'sales' in liveStats %}
                {% set salesCountHoursLabelMap = {
                  '1': 'hour',
                  '6': '6 hours',
                  '12': '12 hours',
                  '24': '24 hours',
                  '168': '7 days',
                  '720': '30 days'
                } %}
                <div class="flex items-center gap-3 sm:gap-1">
                  <span class="w-6 sm:w-5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-5 sm:size-4 text-accent-400" viewBox="0 0 24 24"><path fill="currentColor" d="M7 22q-.825 0-1.412-.587T5 20t.588-1.412T7 18t1.413.588T9 20t-.587 1.413T7 22m10 0q-.825 0-1.412-.587T15 20t.588-1.412T17 18t1.413.588T19 20t-.587 1.413T17 22M5.2 4h14.75q.575 0 .875.513t.025 1.037l-3.55 6.4q-.275.5-.737.775T15.55 13H8.1L7 15h12v2H7q-1.125 0-1.7-.987t-.05-1.963L6.6 11.6L3 4H1V2h3.25z"/></svg>
                  </span>
                  <p>
                    <span class="font-semibold">{{ liveStats.sales }}</span>
                    {{ 'person has' if liveStats.sales == 1 else 'people have' }} purchased this product{{ '.' if not product.sales_count_hours in salesCountHoursLabelMap else (' in the last ' ~ salesCountHoursLabelMap[product.sales_count_hours] ~ '.') }}
                  </p>
                </div>
              {% endif %}
            </div>
          {% endif %}

          {% if productUpsells.length > 0 %}
            <div class="my-8" data-dsr>
              <h2 class="text-xl font-bold text-t-primary mb-4">
                Commonly Bought Together
              </h2>
              <div class="flex flex-wrap gap-4">
                {% set ogProduct = product %}
                {% for upsell in productUpsells %}
                  <div class="w-full">
                    {% render_snippet "product-card-horizontal.njk", product=upsell %}
                  </div>
                {% endfor %}
                {% set product = ogProduct %}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% if 'latestOrders' in liveStats and liveStats.latestOrders|length > 0 %}
  <link href="https://cdn.jsdelivr.net/npm/flag-icons@7.3.2/css/flag-icons.min.css" rel="stylesheet" integrity="sha256-tyPeBlnZW2qWbAF1hQiCt9qo6SOgOSymvJBum+FrrwI=" crossorigin="anonymous">
  <div
    x-data="salesNotifications"
    x-cloak
    class="relative"
  >
    <div 
      x-show="show"
      x-transition:enter="transition-transform ease-in-out duration-500"
      x-transition:enter-start="transform translate-y-full"
      x-transition:enter-end="transform translate-y-0"
      x-transition:leave="transition-transform ease-in duration-500"
      x-transition:leave-start="transform translate-y-0"
      x-transition:leave-end="transform translate-y-full"
      class="fixed z-50 bottom-4 left-4 right-4 sm:right-auto"
    >
      <template x-if="order">
        <div class="bg-background shadow-2xl rounded-xl">
          <div class="flex items-center gap-3 p-1 border-2 border-white/5 bg-white/5 rounded-xl group">
            {% if product.image_urls|length > 0 %}
              <div class="relative">
                <img src="{{ product.image_urls[0] }}" alt="{{ product.name }} image" class="size-[3.75rem] object-cover rounded-lg sm:size-[4.5rem]">
              </div>
            {% endif %}
            <div class="truncate pr-2">
              <p class="text-xs text-t-primary/75 font-light truncate sm:text-sm">
                Someone
                <template x-if="order.country_code">
                  <span>
                    from <i :class="`size-[0.625rem] sm:size-3 rounded fi fi-${order.country_code.toLowerCase()}`"></i>
                  </span>
                </template>
                purchased
              </p>
              <p class="text-sm text-t-primary font-medium truncate sm:text-base">
                {{ product.name }}
              </p>
              <p class="text-xs text-t-primary/75 font-light truncate sm:text-sm">
                <span x-text="getTimeAgo(order.completed_at)"></span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </template>
  </div>

  <script>
    document.addEventListener('alpine:init', () => {
      Alpine.data('salesNotifications', () => ({
        displayTime: 8000,
        initTimeMin: 2000,
        initTimeMax: 4000,
        nextTimeMin: 8000,
        nextTimeMax: 12000,

        latestOrders: {{ liveStats.latestOrders | json }},
        show: false,

        get order() {
          return this.latestOrders.length > 0 ? this.latestOrders[0] : null;
        },

        getRandomInterval(min, max) {
          return Math.floor(Math.random() * (max - min + 1)) + min;
        },

        getTimeAgo(input) {
          const date = (input instanceof Date) ? input : new Date(input);
          const formatter = new Intl.RelativeTimeFormat('en');
          const ranges = {
            years: 3600 * 24 * 365,
            months: 3600 * 24 * 30,
            weeks: 3600 * 24 * 7,
            days: 3600 * 24,
            hours: 3600,
            minutes: 60,
            seconds: 1
          };
          const secondsElapsed = (date.getTime() - Date.now()) / 1000;
          for (let key in ranges) {
            if (ranges[key] < Math.abs(secondsElapsed)) {
              const delta = secondsElapsed / ranges[key];
              return formatter.format(Math.round(delta), key);
            }
          }

          return 'just now';
        },

        showNotification() {
          if (this.latestOrders.length === 0) return;

          this.show = true;
          setTimeout(() => {
            this.show = false;

            setTimeout(() => {
              this.latestOrders.shift();

              if (this.latestOrders.length > 0) {
                setTimeout(() => this.showNotification(), this.getRandomInterval(this.nextTimeMin, this.nextTimeMax));
              }
            }, 500);
          }, this.displayTime);
        },

        init() {
          setTimeout(() => this.showNotification(), this.getRandomInterval(this.initTimeMin, this.initTimeMax));
        }
      }));
    });
  </script>
{% endif %}

<script>
  window.addEventListener('load', () => {
    if (document.querySelector('.splide.main')) {
      const arrows = {{ 'true' if product.image_urls|length > 1 else 'false' }};

      window.splideMain = new Splide('.splide.main', {
        type: 'fade',
        pagination: false,
        autoHeight: true,
        arrows
      });

      if (document.querySelector('.splide.thumbnails')) {
        window.splideThumbnails = new Splide('.splide.thumbnails', {
          rewind: true,
          fixedWidth: 128,
          fixedHeight: 72,
          isNavigation: true,
          arrows: false,
          gap: 12,
          breakpoints: {
            768: {
              fixedWidth: 96,
              fixedHeight: 54,
            },
          },
        });

        window.splideMain.sync(window.splideThumbnails);
      }
    }

    if (window.splideMain) {
      window.splideMain.mount();

      if (window.splideThumbnails) {
        window.splideThumbnails.mount();
      }
    }

    document.querySelectorAll('.splide__slide img').forEach((img) => {
      img.style.removeProperty('display');
    });
  });
</script>