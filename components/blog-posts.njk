{% set data = [] %}
{% if blog_posts %}
  {% set data = blog_posts %}
{% elif latest_blog_posts %}
  {% set data = latest_blog_posts %}
{% endif %}

<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="container mx-auto flex flex-col items-center text-center px-4 mb-16 lg:mb-32">
    {% if properties.headline or properties.title or properties.subtitle %}
      <div class="flex flex-col gap-4 max-w-md text-center mb-8">
        {% if properties.headline %}
          <div class="text-center">
            <span class="inline-block px-6 py-2 rounded-full border-2 border-white/5 bg-white/5 text-accent-100 text-sm font-semibold hover:translate-y-[-2px] transition-transform duration-300 ease-in-out" data-dsr>
              {{ properties.headline | renderString }}
            </span>
          </div>
        {% endif %}
        {% if properties.title %}
          <h2 class="text-4xl lg:text-5xl font-bold text-t-primary" data-dsr>
            {{ properties.title | renderString }}
          </h2>
        {% endif %}
        {% if properties.subtitle %}
          <p class="text-base text-t-primary/50" data-dsr>
            {{ properties.subtitle | renderString }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    {% if data|length > 0 %}
      <div class="flex flex-wrap gap-4 w-full {{ 'justify-center' if properties.centered }}">
        {% for blogPost in data.slice(0, properties.amount) %}
          <div class="w-full sm:w-[calc((100%-1rem)/2)] lg:w-[calc((100%-2rem)/3)] 2xl:w-[calc((100%-3rem)/4)]">
            {% render_snippet "blog-post-card.njk", blogPost=blogPost %}
          </div>
        {% endfor %}
      </div>
      {% if data|length >= properties.amount %}
        <div class="flex justify-center mt-8" data-dsr>
          <a href="{{ '/blog' | shopUrl }}" class="text-accent-500 hover:underline">
            View All Posts
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="text-t-primary/50" data-dsr>
        No Blog Posts Yet.
      </div>
    {% endif %}
  </div>
</section>