<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="container mx-auto flex flex-col items-center text-center px-4 mb-16 lg:mb-32">
    {% if properties.headline or properties.title or properties.subtitle %}
      <div class="flex flex-col gap-4 max-w-md text-center mb-8">
        {% if properties.headline %}
        <div class="text-center">
          <span class="inline-block px-6 py-2 rounded-full border-2 border-white/5 bg-white/5 text-accent-100 text-sm font-semibold hover:translate-y-[-2px] transition-transform duration-300 ease-in-out" data-dsr>
            {{ properties.headline | renderString }}
          </span>
        </div>
        {% endif %}
        {% if properties.title %}
        <h2 class="text-4xl lg:text-5xl font-bold text-t-primary" data-dsr>
          {{ properties.title | renderString }}
        </h2>
        {% endif %}
        {% if properties.subtitle %}
        <p class="text-base text-t-primary/50" data-dsr>
          {{ properties.subtitle | renderString }}
        </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="flex flex-wrap gap-4 w-full {{ 'justify-center' if properties.centered }}">
      {% for category in categories %}
        <div class="w-full sm:w-[calc((100%-1rem)/2)] lg:w-[calc((100%-2rem)/3)] 2xl:w-[calc((100%-3rem)/4)]" data-dsr>
          <a
            class="border-2 border-white/5 rounded-xl bg-[rgba(255,255,255,0.01)] text-t-primary block hover:bg-[rgba(255,255,255,0.05)] transition-colors duration-300 ease-in-out"
            href="{{ category.url }}"
          >
            <div class="relative p-2 mb-4">
              {% if category.image_url %}
                <img src="{{ category.image_url }}" class="rounded-lg w-full aspect-video object-cover" loading="lazy" />
              {% else %}
                <div class="flex justify-center items-center text-accent-400 aspect-video">
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-32" viewBox="0 0 256 256">
                    <path
                      fill="currentColor"
                      d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z"
                    />
                  </svg>
                </div>
              {% endif %}
            </div>
            <div class="text-left px-4 pb-4">
              <h3 class="text-xl font-bold mb-2 truncate">
                {{ category.name }}
              </h3>
              <p class="text-base text-t-primary/50 line-clamp-2 mb-4">
                {{ category.description }}
              </p>

              <div class="flex justify-between items-center">
                <span class="text-sm text-t-primary/50">
                  View Products
                </span>
                <span class="text-accent-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-9" viewBox="0 0 24 24"><path fill="currentColor" d="m12.2 13l-.9.9q-.275.275-.275.7t.275.7t.7.275t.7-.275l2.6-2.6q.3-.3.3-.7t-.3-.7l-2.6-2.6q-.275-.275-.7-.275t-.7.275t-.275.7t.275.7l.9.9H9q-.425 0-.712.288T8 12t.288.713T9 13zm-.2 9q-2.075 0-3.9-.788t-3.175-2.137T2.788 15.9T2 12t.788-3.9t2.137-3.175T8.1 2.788T12 2t3.9.788t3.175 2.137T21.213 8.1T22 12t-.788 3.9t-2.137 3.175t-3.175 2.138T12 22m0-2q3.35 0 5.675-2.325T20 12t-2.325-5.675T12 4T6.325 6.325T4 12t2.325 5.675T12 20m0-8"/></svg>
                </span>
              </div>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>