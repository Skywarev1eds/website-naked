<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="container mx-auto px-4 mb-16 lg:mb-32" data-dsr>
    <div class="p-8 rounded-xl border-2 border-white/5 bg-black/5 backdrop-blur-2xl overflow-hidden relative lg:p-16">
      <div class="mx-auto absolute -z-10 aspect-square rounded-full -translate-y-1/2 left-0 top-0 -translate-x-1/3 blur-3xl bg-accent-500/40 w-[18%]" aria-hidden="true"></div>
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-3 lg:gap-0">
        {% if properties.title or properties.text %}
        <div class="flex flex-col gap-4 lg:border-r lg:border-white/10 lg:pr-8">
          {% if properties.title %}
          <h2 class="text-4xl font-bold text-t-primary">
            {{ properties.title | renderString }}
          </h2>
          {% endif %}
          {% if properties.text %}
            <p class="text-base text-t-primary/50">
              <span class="whitespace-pre-line">{{ properties.text | renderString }}</span>
            </p>
          {% endif %}
        </div>
        {% endif %}
        <div class="flex items-center lg:pl-8 {{ 'lg:col-span-2' if (properties.title or properties.text) else 'lg:col-span-3' }}">
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:gap-8">
            {% for feature in properties.highlights %}
            <div class="flex items-start gap-4">
              <span class="inline-flex justify-center items-center size-12 rounded-xl relative overflow-hidden bg-accent-500/20 border border-accent-500 text-accent-500">
                <i class="{{ feature.icon }}"></i>
              </span>
              <div class="flex-1">
                <h4 class="text-lg font-semibold text-t-primary">
                  {{ feature.title | renderString }}
                </h4>
                <p class="text-t-primary/50">
                  <span class="whitespace-pre-line">{{ feature.description | renderString }}</span>
                </p>
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>