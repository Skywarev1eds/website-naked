{% set statusColorMap = {
  'pending': 'bg-yellow-500/20 text-yellow-500 border-yellow-500/10',
  'confirming': 'bg-blue-500/20 text-blue-500 border-blue-500/10',
  'partially_completed': 'bg-yellow-500/20 text-yellow-500 border-yellow-500/10',
  'completed': 'bg-green-500/20 text-green-500 border-green-500/10',
  'out_of_stock': 'bg-orange-500/20 text-orange-500 border-orange-500/10',
  'refunded': 'bg-teal-500/20 text-teal-500 border-teal-500/10'
} %}

<div class="container mx-auto px-4 my-16 lg:my-32 relative">
  <div class="m-auto absolute inset-x-0 top-0 -z-10 aspect-square rounded-full blur-[300px] bg-accent-500/50 max-w-4xl -translate-y-1/2 w-[65%]" aria-hidden="true"></div>

  <div class="w-full mx-auto flex flex-col gap-4 md:gap-6 lg:gap-8 lg:flex-row">
    <div class="lg:flex-1">
      {% render_snippet "customer-sidebar.njk" %}
    </div>
    <div class="lg:w-3/4">
      <div class="flex flex-col gap-4">
        {% if invoices.data.length > 0 %}
          {% for invoice in invoices.data %}
            {% set statusColor = (statusColorMap[invoice.status] if statusColorMap[invoice.status] else 'bg-gray-500/20 text-gray-500 border-gray-500/10') %}

            <div class="flex flex-col bg-white/5 backdrop-blur-2xl rounded-xl border-2 border-white/5">
              <div class="p-4 md:p-6 lg:p-7">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-2">
                  <a href="{{ invoice.url }}" target="_blank" class="text-lg sm:text-xl text-t-primary font-semibold truncate hover:underline">
                    {% if invoice.items and invoice.items[0] and invoice.items[0].product %}
                      {{ invoice.items[0].product.name }} 
                      {% if invoice.items[0].variant and invoice.items[0].product.name != invoice.items[0].variant.name %}
                        ({{ invoice.items[0].variant.name }})
                      {% endif %}

                      {% if invoice.items.length > 1 %}
                        & {{ invoice.items.length - 1 }} more
                      {% endif %}
                    {% else %}
                      Deleted Products
                    {% endif %}
                  </a>
                  <p>
                    <span class="px-2 py-1 text-xs sm:text-sm border rounded-md {{ statusColor }}">
                      <span class="capitalize">{{ invoice.status | replace('_', ' ') }}</span>
                    </span>
                  </p>
                </div>
                <p class="text-sm sm:text-base text-t-primary/60 mt-4 sm:mt-2">
                  <span class="text-t-primary/80">{{ formatPrice(invoice.price, invoice.currency) }}</span> via <span class="text-t-primary/80">{{ invoice.gateway_formatted }}</span> at <span class="text-t-primary/80">{{ invoice.created_at | formatDate }}</span>.
                </p>
              </div>
              <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between border-t border-white/5 p-4 md:px-6 lg:px-7">
                <a href="{{ invoice.url }}" target="_blank" class="text-sm text-t-primary/60">
                  Invoice <span class="text-accent-500">#{{ invoice.unique_id }}</span>
                </a>
                <div class="flex flex-wrap items-center gap-2 sm:flex-nowrap">
                  {% if shop.tickets_enabled %}
                    {% if invoice.ticket %}
                      <a href="/customer/tickets/{{ invoice.ticket.id }}" class="flex-1 sm:w-auto inline-flex items-center justify-center gap-1.5 px-3 py-1 text-sm border rounded-md bg-white/10 text-t-primary/75 border-white/5 hover:bg-white/20 transition duration-300 ease-in-out">
                        <span class="whitespace-nowrap">View Ticket</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M4 20q-.825 0-1.412-.587T2 18V6q0-.825.588-1.412T4 4h11q.475 0 .9.213t.7.587l4.5 6q.4.525.4 1.2t-.4 1.2l-4.5 6q-.275.375-.7.588T15 20zm0-2h11l4.5-6L15 6H4zm7.75-6"/></svg>
                      </a>
                    {% else %}
                      <button type="button" x-on:click="appTickets.modalOpen('{{ invoice.unique_id }}')" class="flex-1 sm:w-auto inline-flex items-center justify-center gap-1.5 px-3 py-1 text-sm border rounded-md bg-white/10 text-t-primary/75 border-white/5 hover:bg-white/20 transition duration-300 ease-in-out">
                        <span class="whitespace-nowrap">Open Ticket</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M4 20q-.825 0-1.412-.587T2 18V6q0-.825.588-1.412T4 4h11q.475 0 .9.213t.7.587l4.5 6q.4.525.4 1.2t-.4 1.2l-4.5 6q-.275.375-.7.588T15 20zm0-2h11l4.5-6L15 6H4zm7.75-6"/></svg>
                      </button>
                    {% endif %}
                  {% endif %}
                  {% if not invoice.feedback and invoice.is_eligible_for_feedback %}
                    <a href="{{ invoice.url }}#feedback" target="_blank" class="flex-1 sm:w-auto inline-flex items-center justify-center gap-1.5 px-3 py-1 text-sm border rounded-md bg-white/10 text-t-primary/75 border-white/5 hover:bg-white/20 transition duration-300 ease-in-out">
                      <span class="whitespace-nowrap">Leave Feedback</span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M19 15q.3-.3.713-.3t.712.3L22 16.6q.3.3.3.7t-.3.7t-.7.3t-.7-.3L19 16.425q-.3-.3-.3-.712T19 15m1-12q.3.3.3.713t-.3.712L18.425 6q-.3.3-.712.3T17 6t-.3-.712t.3-.713L18.6 3q.3-.3.7-.3t.7.3M4 3q.3-.3.713-.3t.712.3L7 4.6q.3.3.3.7T7 6t-.712.3t-.713-.3L4 4.425q-.3-.3-.3-.712T4 3m1 12q.3.3.3.713t-.3.712L3.425 18q-.3.3-.712.3T2 18t-.3-.712t.3-.713L3.6 15q.3-.3.7-.3t.7.3m3.85 1.825l3.15-1.9l3.15 1.925l-.825-3.6l2.775-2.4l-3.65-.325l-1.45-3.4l-1.45 3.375l-3.65.325l2.775 2.425zm3.15.45l-4.15 2.5q-.275.175-.575.15t-.525-.2t-.35-.437t-.05-.588l1.1-4.725L3.775 10.8q-.25-.225-.312-.513t.037-.562t.3-.45t.55-.225l4.85-.425l1.875-4.45q.125-.3.388-.45t.537-.15t.537.15t.388.45l1.875 4.45l4.85.425q.35.05.55.225t.3.45t.038.563t-.313.512l-3.675 3.175l1.1 4.725q.075.325-.05.588t-.35.437t-.525.2t-.575-.15z"/></svg>
                    </a>
                  {% endif %}
                  <a href="{{ invoice.url }}" target="_blank" class="w-full sm:w-auto inline-flex items-center justify-center gap-1.5 px-3 py-1 text-sm border rounded-md bg-accent-500/10 text-accent-500 border-accent-500/5 hover:bg-accent-500/20 transition duration-300 ease-in-out">
                    <span class="whitespace-nowrap">View Invoice</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M5 21q-.825 0-1.412-.587T3 19V5q0-.825.588-1.412T5 3h6q.425 0 .713.288T12 4t-.288.713T11 5H5v14h14v-6q0-.425.288-.712T20 12t.713.288T21 13v6q0 .825-.587 1.413T19 21zM19 6.4L10.4 15q-.275.275-.7.275T9 15t-.275-.7t.275-.7L17.6 5H15q-.425 0-.712-.288T14 4t.288-.712T15 3h5q.425 0 .713.288T21 4v5q0 .425-.288.713T20 10t-.712-.288T19 9z"/></svg>
                  </a>
                </div>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="flex flex-col p-4 md:p-6 lg:p-7 bg-white/5 backdrop-blur-2xl rounded-xl border-2 border-white/5">
            <p class="text-2xl text-t-primary font-semibold">
              No Orders Yet
            </p>
          </div>
        {% endif %}
      </div>

      {% if invoices.last_page > 1 %}
        {% render_snippet "pagination.njk", paginator=invoices %}
      {% endif %}
    </div>
  </div>
</div>

<div class="components">
  {% for componentId in components_order %}
    {% render_component componentId %}
  {% endfor %}
</div>

{% render_snippet "ticket-create-modal.njk" %}