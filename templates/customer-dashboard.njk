<div class="container mx-auto px-4 my-16 lg:my-32 relative">
  <div class="m-auto absolute inset-x-0 top-0 -z-10 aspect-square rounded-full blur-[300px] bg-accent-500/50 max-w-4xl -translate-y-1/2 w-[65%]" aria-hidden="true"></div>

  <div class="w-full mx-auto flex flex-col gap-4 md:gap-6 lg:gap-8 lg:flex-row">
    <div class="lg:flex-1">
      {% render_snippet "customer-sidebar.njk" %}
    </div>
    <div class="lg:w-3/4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="flex flex-col p-4 md:p-6 lg:p-7 bg-white/5 backdrop-blur-2xl rounded-xl border-2 border-white/5">
          <h3 class="text-lg text-t-primary/80">
            Completed Orders
          </h3>
          <p class="text-2xl text-t-primary font-semibold mt-2">
            {{ shop_customer.total_completed }}
          </p>
        </div>
        <div class="flex flex-col p-4 md:p-6 lg:p-7 bg-white/5 backdrop-blur-2xl rounded-xl border-2 border-white/5">
          <h3 class="text-lg text-t-primary/80">
            Total Spent
          </h3>
          <p class="text-2xl text-t-primary font-semibold mt-2">
            <span x-text="appCurrency.format({{ shop_customer.total_spent_usd }}, 'USD')">
              {{ formatPrice(shop_customer.total_spent_usd, 'USD') }}
            </span>
          </p>
        </div>
        <div class="flex flex-col p-4 md:p-6 lg:p-7 bg-white/5 backdrop-blur-2xl rounded-xl border-2 border-white/5">
          <h3 class="text-lg text-t-primary/80">
            Customer Since
          </h3>
          <p class="text-2xl text-t-primary font-semibold mt-2">
            {{ shop_customer.created_at | formatDate }}
          </p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
        <div class="flex flex-col md:col-span-2 p-4 md:p-6 lg:p-7 bg-white/5 backdrop-blur-2xl rounded-xl border-2 border-white/5">
          <h3 class="text-lg text-t-primary/80">
            Latest Order
          </h3>
          {% if latest_invoice %}
            <div class="mt-2">
              <p class="text-2xl text-t-primary font-semibold truncate">
                {% if latest_invoice.items %}
                  {{ latest_invoice.items[0].product.name }} 
                  {% if latest_invoice.items[0].variant and latest_invoice.items[0].product.name != latest_invoice.items[0].variant.name %}
                    ({{ latest_invoice.items[0].variant.name }})
                  {% endif %}

                  {% if latest_invoice.items.length > 1 %}
                    & {{ latest_invoice.items.length - 1 }} more
                  {% endif %}
                {% else %}
                  Deleted Product
                {% endif %}
              </p>
              <p class="mt-2 text-sm text-t-primary/60">
                <a href="{{ latest_invoice.url }}" target="_blank">
                  Invoice <span class="text-accent-500 hover:text-accent-600">#{{ latest_invoice.unique_id }}</span>
                </a>
                  - {{ latest_invoice.created_at | formatDate }}
              </p>
            </div>
          {% else %}
            <p class="text-2xl text-t-primary font-semibold mt-2">
              None
            </p>
          {% endif %}
        </div>
        {% if shop.customer_balance_enabled %}
          <div class="flex flex-col p-4 md:p-6 lg:p-7 bg-white/5 backdrop-blur-2xl rounded-xl border-2 border-white/5">
            <h3 class="text-lg text-t-primary/80">
              Balance
            </h3>
            <div class="mt-2">
              <p class="text-2xl text-t-primary font-semibold">
                <span x-text="appCurrency.format({{ shop_customer.balance }}, 'USD')">
                  {{ formatPrice(shop_customer.balance, 'USD') }}
                </span>
              </p>
              <p class="mt-2 text-sm text-t-primary/60">
                <a href="{{ '/customer/balance' | shopUrl }}">
                  <span class="text-accent-500 hover:text-accent-600">Top Up</span>
                </a>
              </p>
            </div>
          </div>
        {% endif %}
      </div>
      <div class="mt-4 flex justify-end gap-4">
        {% if has_multiple_sessions %}
          <button
            type="button"
            @click="appCustomer.logoutOtherSessions()"
            class="px-6 py-2 rounded-full inline-flex justify-center items-center gap-3 border-2 text-sm font-semibold bg-transparent border-white/5 text-t-primary hover:bg-white/10 hover:border-white/10 transition-colors duration-300 ease-in-out"
          >
            <span>Logout Other Devices</span>
            <template x-if="!appCustomer.loggingOutOtherSessions">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M5 21q-.825 0-1.412-.587T3 19v-4h2v4h14V5H5v4H3V5q0-.825.588-1.412T5 3h14q.825 0 1.413.588T21 5v14q0 .825-.587 1.413T19 21zm5.5-4l-1.4-1.45L11.65 13H3v-2h8.65L9.1 8.45L10.5 7l5 5z"/></svg>
            </template>
            <template x-if="appCustomer.loggingOutOtherSessions">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-dasharray="16" stroke-dashoffset="16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3c4.97 0 9 4.03 9 9"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.2s" values="16;0"/><animateTransform attributeName="transform" dur="1.5s" repeatCount="indefinite" type="rotate" values="0 12 12;360 12 12"/></path></svg>
            </template>
          </button>
        {% endif %}
        <button
          type="button"
          @click="appCustomer.openDeleteModal()"
          class="px-6 py-2 rounded-full inline-flex justify-center items-center gap-3 border-2 text-sm font-semibold bg-transparent border-red-500 text-red-500 hover:bg-red-500/10 transition-colors duration-300 ease-in-out"
        >
          <span>Delete Account</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="size-3.5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M7 21q-.825 0-1.412-.587T5 19V6H4V4h5V3h6v1h5v2h-1v13q0 .825-.587 1.413T17 21zm2-4h2V8H9zm4 0h2V8h-2z"/></svg>
        </button>
      </div>
    </div>
  </div>
</div>

<div
  x-show="appCustomer.deleteModalIsOpen"
  x-cloak
  class="fixed inset-0 z-50 overflow-y-auto"
  aria-labelledby="delete-modal-title"
  role="dialog"
  aria-modal="true"
>
  <div class="flex items-center justify-center min-h-screen px-4 text-center">
    <div
      x-show="appCustomer.deleteModalIsOpen"
      x-transition:enter="transition ease-out duration-300 transform"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition ease-in duration-200 transform"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      @click="appCustomer.closeDeleteModal()"
      class="fixed inset-0 transition-opacity bg-black/75"
      aria-hidden="true"
    ></div>
    <div
      x-show="appCustomer.deleteModalIsOpen"
      x-transition:enter="transition ease-out duration-300 transform"
      x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
      x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
      x-transition:leave="transition ease-in duration-200 transform"
      x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
      x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
      class="inline-block w-full max-w-lg p-6 my-8 overflow-hidden text-left align-middle transition-all transform border-2 border-white/5 rounded-xl bg-background text-t-primary"
    >
      <div class="flex items-start justify-between gap-4 mb-4">
        <h3 id="delete-modal-title" class="text-xl font-bold truncate">
          Delete Customer Account
        </h3>
        <button @click="appCustomer.closeDeleteModal()" class="text-t-primary focus:outline-none hover:text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-6" viewBox="0 0 24 24"><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
        </button>
      </div>
      <p class="text-t-primary/80 mb-6">
        This action cannot be undone and will permanently remove all your data, order history and balance.
      </p>
      <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 sm:gap-4">
        <button
          type="button"
          @click="appCustomer.closeDeleteModal()"
          class="px-6 py-2 rounded-full flex-1 flex justify-center items-center gap-2 border-2 font-semibold bg-white/5 border-white/5 text-t-primary hover:bg-white/10 hover:border-white/10 transition-colors duration-300 ease-in-out"
        >
          <span>Cancel</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="m12 13.4l-4.9 4.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7l4.9-4.9l-4.9-4.9q-.275-.275-.275-.7t.275-.7t.7-.275t.7.275l4.9 4.9l4.9-4.9q.275-.275.7-.275t.7.275t.275.7t-.275.7L13.4 12l4.9 4.9q.275.275.275.7t-.275.7t-.7.275t-.7-.275z"/></svg>
        </button>
        <button
          type="button"
          @click="appCustomer.deleteAccount()"
          class="px-6 py-2 rounded-full flex-1 flex justify-center items-center gap-2 border-2 font-semibold bg-red-500 border-red-500 text-white hover:enabled:bg-red-600 hover:enabled:border-red-600 transition-colors duration-300 ease-in-out disabled:opacity-50 disabled:pointer-events-none"
          :disabled="appCustomer.deleteModalLoading"
        >
          <span>Delete Account</span>
          <template x-if="!appCustomer.deleteModalLoading">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M7 21q-.825 0-1.412-.587T5 19V6H4V4h5V3h6v1h5v2h-1v13q0 .825-.587 1.413T17 21zm2-4h2V8H9zm4 0h2V8h-2z"/></svg>
          </template>
          <template x-if="appCustomer.deleteModalLoading">
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-dasharray="16" stroke-dashoffset="16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3c4.97 0 9 4.03 9 9"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.2s" values="16;0"/><animateTransform attributeName="transform" dur="1.5s" repeatCount="indefinite" type="rotate" values="0 12 12;360 12 12"/></path></svg>
          </template>
        </button>
      </div>
    </div>
  </div>
</div>

<div class="components">
  {% for componentId in components_order %}
    {% render_component componentId %}
  {% endfor %}
</div>